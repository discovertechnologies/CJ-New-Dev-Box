<?xml version="1.0" encoding="UTF-8"?><record_update table="sys_ui_macro">
    <sys_ui_macro action="INSERT_OR_UPDATE">
        <active>true</active>
        <category>general</category>
        <description>HTML Template used in the Angular Provider Directive: dtechSubTasks&#13;
2.8.5 | 2023-08-14 | raj | STRY0136615 - STRETCH-PLACEHOLDER- Header UI Control (updates to add lable and change the style for label and text)</description>
        <media_type/>
        <name>dtechSubTasks.html</name>
        <scoped_name>x_153465_discovert_dtechSubTasks.html</scoped_name>
        <sys_class_name>sys_ui_macro</sys_class_name>
        <sys_created_by>rjoy</sys_created_by>
        <sys_created_on>2023-08-15 16:25:33</sys_created_on>
        <sys_id>522903ef1ba8b110e75655f5624bcb34</sys_id>
        <sys_mod_count>28</sys_mod_count>
        <sys_name>dtechSubTasks.html</sys_name>
        <sys_package display_value="Tasker" source="x_153465_discovert">c6b1162d4fc10300303dc3818110c7b1</sys_package>
        <sys_policy/>
        <sys_scope display_value="Tasker">c6b1162d4fc10300303dc3818110c7b1</sys_scope>
        <sys_update_name>sys_ui_macro_522903ef1ba8b110e75655f5624bcb34</sys_update_name>
        <sys_updated_by>rjoy</sys_updated_by>
        <sys_updated_on>2023-08-18 23:44:08</sys_updated_on>
        <xml><![CDATA[<span role="button"
	 ng-click="d.openModal($event);d.leaveTooltip();"> 

	<span ng-mouseenter="d.showSubTasks($event);" 
		 ng-mouseleave="d.parentMouseLeave();">

		<span uib-popover-template="'template-sub-tasks.html'"
			 popover-trigger="none"
			 popover-is-open="dtechSubTasksToolTipOpen"
			 popover-placement="auto"
			 popover-animation="true"
			 popover-class="dtech-popover-container-duration" 
			 popover-append-to-body="dtechIsModal==false"
			 popover-popup-delay="{{d.popoverDelay}}">
			<span ng-if="dtechShowLabel==true"
				  class="flex-row text-nowrap text-uppercase">
				{{dtechSubTasksObject.calchaschildren.label}}
			</span>
			<span class="'flex-row'">
				<span >
					<span class="badge Draft" >
						{{dtechSubTasksObject.calchaschildren.display_value}}
					</span>
				</span>
			</span>
		</span>
	</span>
	<script type="text/ng-template" id="template-sub-tasks.html">
		<div ng-mouseenter="d.enterTooltip();"
			 ng-mouseleave="d.leaveTooltip();"
			 ng-init="d.initTooltip();"
			 class="flex-column">
<!-- TODO discuss with Mark McCune if we should make this universal or create a different class for SubTasks -->
			<div class="dtech-template-container-270">
				<div ng-if="d.isSpinnerShown">
					<div class="dtech-popover-list-spinner-content">
						<fa name="spinner" spin="true"></fa>
					</div>
				</div>
				<div class="flex-column"
					 ng-if="!d.isSpinnerShown">
					<ul class="list-unstyled">
						<li class="dtech-margin-bottom-inherit" ng-repeat="subtask in dtechSubTasksObject.subtasks | limitTo: maxRowsToDisplay track by subtask.taskId">
							<div class="flex-column">
								<span class="dtech-modal-widget-text-black-bold"
									  ng-click="itemClick(subtask.taskId)">{{subtask.short_description.display_value}}</span>
								<span class="dtech-state-indicator-row">
									<span class="dtech-circle dtech-circle-12 {{subtask.state.display_value}}"></span>
									<span class="flex-grow dtech-sonic-silver-text-color">{{subtask.state.display_value}}</span>
								</span>
							</div>
						</li>
					</ul>
				</div>
			</div>
			<div class="dtech-flex-shrink-0">
				<div class="dtech-pad-top-10">
					<div class="dtech-avatar-link dtech-display-block text-center" ng-click="d.openModal($event)">
						${gs.getMessage("Tasker - Open SubTasks")}
					</div>
				</div>
			</div>
		</div>
	</script>
</span>
]]></xml>
    </sys_ui_macro>
</record_update>
