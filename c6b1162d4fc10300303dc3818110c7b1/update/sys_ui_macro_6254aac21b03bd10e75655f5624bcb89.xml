        <sys_package display_value="Tasker" source="x_153465_discovert">c6b1162d4fc10300303dc3818110c7b1</sys_package>
        <sys_policy/>
        <sys_scope display_value="Tasker">c6b1162d4fc10300303dc3818110c7b1</sys_scope>
        <sys_update_name>sys_ui_macro_6254aac21b03bd10e75655f5624bcb89</sys_update_name>
        <sys_updated_by>rjoy</sys_updated_by>
        <sys_updated_on>2023-12-14 02:47:23</sys_updated_on>
        <xml><![CDATA[<span role="button" > 
	<span ng-mouseenter="d.showOrder();" 
		 ng-mouseleave="d.parentMouseLeave();">

		<span uib-popover-template="'dtech-popover-order.html'"
			 popover-trigger="none"
			 popover-is-open="dtechToolTipOpen"
			 popover-placement="{{dtechPopoverPlacement}}"
			 popover-animation="true"
			 popover-class="dtech-order-container" 
			 popover-append-to-body="dtechIsModal==false"
			 popover-popup-delay="{{d.popoverDelay}}">
			<span class="pointer dtech-order-circle" >
<!-- TODO - NEED TO MAKE THIS 2 DIGITS-->
				{{dtechOrderObject.route_order.value}}
			</span>
		</span>
	</span>
	<script type="text/ng-template" id="dtech-popover-order.html">
		<span ng-mouseenter="d.enterTooltip();"
			 ng-mouseleave="d.leaveTooltip();"
			 ng-init="d.initTooltip();"
			 class="flex-column">
			 <span>${gs.getMessage("Select Order")}</span>
			 <span class="dtech-order-dropdown">
				<span ng-show="dtechOrderList.length==0">
					<span class="dtech-action-menu-spinner-container">
						<fa name="spinner" spin="true"></fa>
					</span>
				</span>
				<span class="flex-column"
					ng-show="dtechOrderList.length>0">
					<span ng-repeat="orderItem in dtechOrderList | orderBy : 'value' track by orderItem.value"
						class="flex-row">
						<span ng-class="{'dtech-order-item': !orderItem.selected,
										'dtech-order-item-selected': displayOrder.selected}"						
							 ng-click="orderItem.selected || d.changeOrder($event, orderItem);d.leaveTooltip();">
								{{orderItem.display_value}}
						</span>
					</span>
				</span>
			</span>
		</span>
	</script>	
</span>
]]></xml>
    </sys_ui_macro>
</record_update>
