(function executeRule(current, previous /*null when async*/) {

	// If top OU changes, update children
	var grChildOUs = new GlideRecord('x_153465_discovert_discover_office_hierarchy');
	grChildOUs.addQuery('parent', current.getUniqueValue());
	grChildOUs.query();
	while(grChildOUs.next()){
		grChildOUs.u_top_ou = current.u_top_ou;
		grChildOUs.update();
	}
})(current, previous);]]></script>
