function createProcessTopTaskerDef() {&#13;
	&#13;
	// Tasker Definition Record&#13;
	var recTaskDef = new GlideRecord('x_153465_discovert_route_tasks');&#13;
	recTaskDef.initialize();&#13;
	// set the process definition for the Tasker Def&#13;
	recTaskDef.tasker_process_definition = current.sys_id;&#13;
	recTaskDef.original_tasker_inst = current.original_tasker_saved_to_process;&#13;
	recTaskDef.insert();&#13;
	&#13;
	&#13;
	// Set the Top Task on the Process Instance&#13;
	current.parent_task_def = recTaskDef.sys_id;&#13;
	current.update();&#13;
	&#13;
}</value>
