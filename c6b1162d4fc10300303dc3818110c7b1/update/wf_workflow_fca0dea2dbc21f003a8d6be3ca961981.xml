        <value>answer = createTopTaskerDefinitions();&#13;
function createTopTaskerDefinitions() {&#13;
	&#13;
	workflow.scratchpad.u_routes_order_count +=1;&#13;
	&#13;
	// we use aggregate query to get the count of task instances in this "route order"&#13;
	var countTasksInOrder = 0;&#13;
	var agTaskInstanceQuery = new GlideAggregate('x_153465_discovert_route_task_instance');&#13;
	agTaskInstanceQuery.addQuery('parent',current.getValue('original_tasker_saved_to_process')).addCondition('order',workflow.scratchpad.u_routes_order_count);&#13;
	agTaskInstanceQuery.addAggregate('COUNT');&#13;
	agTaskInstanceQuery.query();&#13;
	if(agTaskInstanceQuery.next()){&#13;
		countTasksInOrder = agTaskInstanceQuery.getAggregate('COUNT');&#13;
	}&#13;
	&#13;
	&#13;
	// we query to get the list of all Task instances in this "route order"&#13;
	// the loop below will process each Task instance in this route order&#13;
	// it will increment the total Task instances processed for each order&#13;
	var taskInstanceQuery = new GlideRecord('x_153465_discovert_route_task_instance');&#13;
	taskInstanceQuery.addQuery('parent',current.getValue('original_tasker_saved_to_process')).addCondition('order',workflow.scratchpad.u_routes_order_count);&#13;
	taskInstanceQuery.query();&#13;
	&#13;
	var wf = new global.Workflow();&#13;
	while (taskInstanceQuery.next()){&#13;
		&#13;
		var recTaskDef = new GlideRecord('x_153465_discovert_route_tasks');&#13;
		recTaskDef.initialize();&#13;
		recTaskDef.parent = current.getValue('parent_task_def');&#13;
		&#13;
		recTaskDef.tasker_process_definition = current.sys_id;&#13;
		&#13;
		recTaskDef.original_tasker_inst = taskInstanceQuery.sys_id;&#13;
		// NOTE: TODO: set number to parent number here...&#13;
		recTaskDef.insert();&#13;
		var  wfId = wf.getWorkflowFromName("Discover Save Tasks to Process");&#13;
		wf.startFlow(wfId, recTaskDef, 'Update');&#13;
		// increment the total routes processed for each route in this order&#13;
		workflow.scratchpad.u_routes_loaded_count +=1;&#13;
	}&#13;
	&#13;
}&#13;
</value>
