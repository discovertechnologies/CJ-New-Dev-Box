        <script><![CDATA[// Copyrights belong to Discover Technologies LLC. © 2019 Discover Technologies LLC
// Script Continued Below
(function executeRule(current, previous /*null when async*/) {
	// STRY0076605 - if wait state changes, adjust the state of the task 
	var TaskerHelper = new TaskerHelpers();
	current.state = TaskerHelper.getUpdatedState(current);
	
	if(current.u_wait_for_subtasks_to_finish){
		// STRY0076596 - set task owner to parent task owner or originator
		if (current.parent.nil()){
			current.u_task_requester = current.originator;
		} else{
			// STRY0078378 - if task owner of parent not set, set the owner of the subtask to the originator of the parent
			if (current.parent.u_task_requester){
				current.u_task_requester = current.parent.u_task_requester;
			} else {
				current.u_task_requester = current.parent.originator;
			}
		}		
	}
})(current, previous);]]></script>
