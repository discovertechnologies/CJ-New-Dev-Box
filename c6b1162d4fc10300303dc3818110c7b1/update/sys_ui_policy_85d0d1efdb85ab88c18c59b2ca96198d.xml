        <script_false><![CDATA[function onCondition() {
	g_form.setDisplay('tasking_authority.u_external_flag',false);
	g_form.setDisabled('outbound', false);
	g_form.setDisplay('u_external_ou',false);

}]]></script_false>
        <script_true><![CDATA[function onCondition() {
	g_form.setDisplay('tasking_authority.u_external_flag',false);
	// check for external Tasking Authority on the parent
	if((g_form.getValue('tasking_authority.u_external_flag') == 'true') && (g_form.getValue('parent')+'' == '')){
		g_form.setDisabled('outbound', true);
		g_form.setDisabled('u_external_ou', true);
		g_form.setDisplay('u_external_ou',false);
   }else{
		// NOTE: This needs to move into Patch Permissions not here...
		g_form.setDisabled('outbound', false);
		g_form.setDisabled('u_external_ou',false);
		g_form.setDisplay('u_external_ou',true);
   }
}]]></script_true>
