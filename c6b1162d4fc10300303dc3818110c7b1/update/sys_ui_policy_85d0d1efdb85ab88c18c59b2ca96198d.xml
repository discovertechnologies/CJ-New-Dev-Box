        <active>true</active>
        <conditions table="x_153465_discovert_route_task_instance">parentISEMPTY^tasking_authority.u_external_flag=true^NQoutbound=true^EQ<item endquery="false" field="parent" goto="false" newquery="false" operator="ISEMPTY" or="false" value=""/>
            <item endquery="false" field="tasking_authority.u_external_flag" goto="false" newquery="false" operator="=" or="false" value="true"/>
            <item endquery="false" field="outbound" goto="false" newquery="true" operator="=" or="false" value="true"/>
