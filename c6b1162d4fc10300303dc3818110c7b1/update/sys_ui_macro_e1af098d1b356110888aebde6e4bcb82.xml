<?xml version="1.0" encoding="UTF-8"?><record_update table="sys_ui_macro">
    <sys_ui_macro action="INSERT_OR_UPDATE">
        <active>true</active>
        <category>general</category>
        <description>HTML Template used in the Angular Provider Directive: dtechResponseComments &#13;
&#13;
2.8.1 | 2023-04-19 | mmcc | STRY0135713 - Modal showing all comments when clicking the Response Column&#13;
Rename to dtechResponseComments.html and update ngClick to use  d.openModalResponseComments&#13;
Update ngClick to openModalResponseComments()&#13;
2.8.1 | 2023-04-04 | mmcc | STRY0135723 - Homepage Comments column replaced by Task Comments&#13;
Created HTML Template&#13;
</description>
        <media_type/>
        <name>dtechResponseComments.html</name>
        <scoped_name>x_153465_discovert_dtechResponseComments.html</scoped_name>
        <sys_class_name>sys_ui_macro</sys_class_name>
        <sys_created_by>mmccune</sys_created_by>
        <sys_created_on>2023-03-23 21:29:46</sys_created_on>
        <sys_customer_update>false</sys_customer_update>
        <sys_id>e1af098d1b356110888aebde6e4bcb82</sys_id>
        <sys_mod_count>106</sys_mod_count>
        <sys_name>dtechResponseComments.html</sys_name>
        <sys_package display_value="Tasker" source="x_153465_discovert">c6b1162d4fc10300303dc3818110c7b1</sys_package>
        <sys_policy/>
        <sys_replace_on_upgrade>false</sys_replace_on_upgrade>
        <sys_scope display_value="Tasker">c6b1162d4fc10300303dc3818110c7b1</sys_scope>
        <sys_update_name>sys_ui_macro_e1af098d1b356110888aebde6e4bcb82</sys_update_name>
        <sys_updated_by>mmccune</sys_updated_by>
        <sys_updated_on>2023-04-19 17:13:49</sys_updated_on>
        <xml><![CDATA[<div role="button"
	 ng-click="d.openModal($event);d.leaveTooltip();"> 

	<div ng-mouseenter="d.showResponse($event);" 
		 ng-mouseleave="d.parentMouseLeave();"> 

		<div uib-popover-template="'template-response.html'"
			 popover-trigger="none"
			 popover-is-open="dtechResponseToolTipOpen"
			 popover-placement="auto left"
			 popover-animation="true"
			 popover-class="dtech-popover-container-response" 
			 popover-append-to-body="dtechIsModal==false"
			 popover-popup-delay="250">
			<div>
				<img class="dtech-pad-right-20" src="ResponseComment16.svg"/>
				<img ng-if="dtechResponseComments.length>0" 
					 ng-class="{'dtech-pad-right-10':dtechReviewerComments.length>0 || dtechReworkComments.length>0 || dtechReopenComments.length>0}"
					 src="Comment10.svg"/>
				<img ng-if="dtechReviewerComments.length>0"
					 ng-class="{'dtech-pad-right-10':dtechReworkComments.length>0 || dtechReopenComments.length>0}" src="View10.svg"/>
				<img ng-if="dtechReworkComments.length>0"
					 ng-class="{'dtech-pad-right-10':dtechReopenComments.length>0}" src="Rework10.svg"/>
				<img ng-if="dtechReopenComments.length>0" src="Reopen10.svg"/>
			</div>
		</div>
	</div>

	<script type="text/ng-template" id="template-response.html">
		<div ng-mouseenter="d.enterTooltip();"
			 ng-mouseleave="d.leaveTooltip();"
			 class="flex-column">

			<div class="dtech-template-response-container">
				<div ng-if="dtechResponseComments.length>0" class="panel panel-default">
					<div class="panel-heading">
						<h3 class="panel-title">${gs.getMessage("Tasker - Response Comments")}</h3>
					</div>
					<div class="panel-body dtech-margin-top-5px">
						<div ng-bind-html="dtechResponseComments"></div>
					</div>
				</div>

				<div ng-if="dtechReviewerComments.length>0" class="panel panel-default">
					<div class="panel-heading">
						<h3 class="panel-title">${gs.getMessage("Tasker - Reviewer Comments")}</h3>
					</div>
					<div class="panel-body dtech-margin-top-5px">
						<div ng-bind-html="dtechReviewerComments"></div>
					</div>
				</div>

				<div ng-if="dtechReworkComments.length>0" class="panel panel-default">
					<div class="panel-heading">
						<h3 class="panel-title">${gs.getMessage("Tasker - Rework Comments")}</h3>
					</div>
					<div class="panel-body dtech-margin-top-5px">
						<div ng-bind-html="dtechReworkComments"></div>
					</div>
				</div>
				
				<div ng-if="dtechReopenComments.length>0" class="panel panel-default">
					<div class="panel-heading">
						<h3 class="panel-title">${gs.getMessage("Tasker - Reopen Comments")}</h3>
					</div>
					<div class="panel-body dtech-margin-top-5px">
						<div ng-bind-html="dtechReopenComments"></div>
					</div>
				</div>
			</div>

			<div class="dtech-flex-shrink-0">
				<div class="dtech-pad-top-10">
					<div class="dtech-avatar-link dtech-display-block text-center" ng-click="d.openModalResponseComments($event)">
						${gs.getMessage("Tasker - Show All Responses...")}
					</div>
				</div>
			</div>
		</div>
	</script>
</div>
]]></xml>
    </sys_ui_macro>
</record_update>
