<?xml version="1.0" encoding="UTF-8"?><record_update table="sys_ui_macro">
    <sys_ui_macro action="INSERT_OR_UPDATE">
        <active>true</active>
        <category>general</category>
        <description>HTML Template used in the Angular Provider Directive State Legend&#13;
This directive allows us to put the same style on the State Legend anywhere we want to use it.  &#13;
It will show when hovered.  It will show pinned.</description>
        <media_type/>
        <name>dtechStateLegend.html</name>
        <scoped_name>x_153465_discovert_dtechStateLegend.html</scoped_name>
        <sys_class_name>sys_ui_macro</sys_class_name>
        <sys_created_by>rjoy</sys_created_by>
        <sys_created_on>2024-02-24 14:38:45</sys_created_on>
        <sys_id>41aa64bd1b64c2103ed2eb93b24bcb84</sys_id>
        <sys_mod_count>23</sys_mod_count>
        <sys_name>dtechStateLegend.html</sys_name>
        <sys_package display_value="Tasker" source="x_153465_discovert">c6b1162d4fc10300303dc3818110c7b1</sys_package>
        <sys_policy/>
        <sys_scope display_value="Tasker">c6b1162d4fc10300303dc3818110c7b1</sys_scope>
        <sys_update_name>sys_ui_macro_41aa64bd1b64c2103ed2eb93b24bcb84</sys_update_name>
        <sys_updated_by>rjoy</sys_updated_by>
        <sys_updated_on>2024-03-01 02:03:20</sys_updated_on>
        <xml><![CDATA[<span role="button"
	 ng-click="d.showStateLegend();d.leaveTooltip();"> 

	<span ng-mouseenter="d.showStateLegend();" 
		 ng-mouseleave="d.parentMouseLeave();">

		<span uib-popover-template="'popover-state-legend.html'"
			 popover-trigger="none"
			 popover-is-open="dtechToolTipOpen"
			 popover-placement="{{dtechPopoverPlacement}}"
			 popover-animation="true"
			 popover-append-to-body="dtechIsModal==false"
			 popover-popup-delay="{{d.popoverDelay}}">
			<span class="text-nowrap flex-row dtech-btn-state">
					<img src="x_153465_discovert.Legend48.svg" />
			</span>
		</span>
	</span>
	<script type="text/ng-template" id="popover-state-legend.html">
		<div ng-mouseenter="d.enterTooltip();"
			 ng-mouseleave="d.leaveTooltip();"
			 ng-init="d.initTooltip();"
			 class="flex-column">
				<div ng-click="d.pinStateLegend($event);d.leaveTooltip();"
						class="flex-row align-items-center dtech-state-legend-item">
					<div>
					<img class="dtech-state-indicator-padding"
							src="x_153465_discovert.Pin16.svg" title="${Hide Legend}"
							alt="${Hide Legend}" />
					</div>
					<div class="dtech-legend-text">${gs.getMessage("Pin this menu")}</div>
				</div>
				
				<div class="dtech-action-menu-item-divider dtech-margin-right-left-negative-20px"/>
				
				<div class="flex-row align-items-center dtech-state-legend-item" 
					ng-repeat="state in dtechLegendStates">
					<div class="dtech-state-indicator-padding"><div class="dtech-circle-legend {{state.value}}"/></div>
					<div class="dtech-legend-text">{{state.label}}</div>
				</div>
				<!-- <span class="label label-Closed.Incomplete">Closed Incomplete</span> -->
				<!-- <span class="label label-Cancelled">Cancelled</span>  -->      

				<div class="dtech-action-menu-item-divider dtech-margin-right-left-negative-20px"/>

				<div class="flex-row align-items-center dtech-state-legend-item" >
					<div><img class="dtech-state-indicator-padding" src="x_153465_discovert.Warning16.svg"/></div>
					<div class="dtech-legend-text">${gs.getMessage("Warning")}</div>
				</div>
				<div class="flex-row align-items-center dtech-state-legend-item" >
					<div><img class="dtech-state-indicator-padding" src="x_153465_discovert.Error16.svg"/></div>
					<div class="dtech-legend-text">${gs.getMessage("Critical")}</div>
				</div>				
		</div>
	</script>
</span>
]]></xml>
    </sys_ui_macro>
</record_update>
