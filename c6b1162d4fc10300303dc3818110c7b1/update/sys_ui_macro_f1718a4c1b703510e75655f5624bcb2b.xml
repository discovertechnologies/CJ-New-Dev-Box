<?xml version="1.0" encoding="UTF-8"?><record_update table="sys_ui_macro">
    <sys_ui_macro action="INSERT_OR_UPDATE">
        <active>true</active>
        <category>general</category>
        <description>HTML Template used in the Angular Provider Directive: dtechItemMembers&#13;
2.8.5 | 2023-08-14 | raj | STRY0136615 - STRETCH-PLACEHOLDER- Header UI Control (updates to add lable and change the style for label and text)</description>
        <media_type/>
        <name>dtechItemMembers.html</name>
        <scoped_name>x_153465_discovert_dtechItemMembers.html</scoped_name>
        <sys_class_name>sys_ui_macro</sys_class_name>
        <sys_created_by>rjoy</sys_created_by>
        <sys_created_on>2023-08-17 00:29:16</sys_created_on>
        <sys_id>f1718a4c1b703510e75655f5624bcb2b</sys_id>
        <sys_mod_count>97</sys_mod_count>
        <sys_name>dtechItemMembers.html</sys_name>
        <sys_package display_value="Tasker" source="x_153465_discovert">c6b1162d4fc10300303dc3818110c7b1</sys_package>
        <sys_policy/>
        <sys_scope display_value="Tasker">c6b1162d4fc10300303dc3818110c7b1</sys_scope>
        <sys_update_name>sys_ui_macro_f1718a4c1b703510e75655f5624bcb2b</sys_update_name>
        <sys_updated_by>rjoy</sys_updated_by>
        <sys_updated_on>2024-05-06 15:20:20</sys_updated_on>
        <xml><![CDATA[<span role="button"> 
	<span ng-mouseenter="d.showItemMembers();" 
		 ng-mouseleave="d.parentMouseLeave();">

		<span uib-popover-template="'template-item-members.html'"
			 popover-trigger="none"
			 popover-is-open="dtechToolTipOpen"
			 popover-placement="{{dtechPopoverPlacement}}"
			 popover-animation="true"
			 popover-class="dtech-popover-container-box-shadow dtech-width-400px" 
			 popover-append-to-body="dtechIsModal==false"
			 popover-popup-delay="{{d.popoverDelay}}">

			<span ng-if="dtechShowLabel==true"
				  class="flex-row text-nowrap text-uppercase">
				${gs.getMessage("Tasker - Members")}
			</span>
			<span id="membersSpan"
				class="dtech-stack-circle-wrapper flex-row dtech-border-none"
				ng-class="{'dtech-btn':dtechHideHoverPanel!=true}">
				<div ng-repeat="member in dtechItemMembersObject.members | orderBy : '-order' | limitTo: dtechImagesToDisplay track by $index"
					 ng-class="{'dtech-border-stack-circle-{{member.order}}': dtechHideHoverPanel!=true,
					 'dtech-stack-circle-{{member.order}}': dtechHideHoverPanel==true}" >
					<span ng-if="member.photoInfo" class="avatar-container dtech-avatar-round-{{dtechUserImageSize}}rem" >
<!--
						<div class="dtech-ooo-item-container">
							<div class="dtech-ooo-item"
								 ng-class="{'dtech-ooo-indicator': member.photoInfo.isOoO==true}" />
						</div>
-->
<!-- 
	<div class="avatar soloAvatar dtech-avatar-bg-color-transparent">
	box-shadow: 0px 2px 6px 0px rgba(0, 0, 0, 75);
-->						
						<div class="avatar soloAvatar dtech-avatar-bg-color-transparent">
							<div  ng-if="member.photoInfo.hasPhoto==true"
								class="sub-avatar dtech-avatar-bg-color" 
								style="{{member.photoInfo.photo}}">
							</div>
							<div ng-if="member.photoInfo.hasPhoto!=true"
								class="dtech-avatar-initials-bg-color dtech-avatar-round-{{dtechUserImageSize}}rem">
								{{member.photoInfo.initials}}
							</div>
						</div>
						<div class="dtech-ooo-item-container">
							<div class="dtech-ooo-item-13" ng-show = "member.photoInfo.isOoO==true">
								<img src="x_153465_discovert.OutOfOffice13.svg" />
							</div>
						</div>
					</span>
					<span ng-if="!member.photoInfo" class="avatar-container dtech-avatar-round-{{dtechUserImageSize}}rem" >
						<div class="dtech-avatar-initials-bg-color dtech-avatar-round-{{dtechUserImageSize}}rem">
							?
						</div>
						<div class="dtech-ooo-item-container">
							<div class="dtech-ooo-item-13" ng-show = "member.photoInfo.isOoO==true">
								<img src="x_153465_discovert.OutOfOffice13.svg" />
							</div>
						</div>
					</span>
				</div>
			</span>
		</span>
	</span>
	<script type="text/ng-template" id="template-item-members.html">
		<div ng-mouseenter="d.enterTooltip();"
			 ng-mouseleave="d.leaveTooltip();"
			 ng-init="d.initTooltip();"
			 class="flex-column dtech-action-menu-container">
			<div>
				<div ng-if="dtechItemMembersObject.loaded!=true">
					<div class="dtech-popover-list-spinner-content">
						<fa name="spinner" spin="true"></fa>
					</div>
				</div>
				<div class="dtech-template-standard-container flex-column"
					 ng-if="dtechItemMembersObject.loaded==true">
					<ul class="list-unstyled">
						<li class="dtech-action-dropdown" ng-repeat="member in dtechItemMembersObject.members | limitTo: dtechMaxRowsToDisplay"
							ng-click="d.openUserProfileModal($event, member.value)">
							<div class="flex-row flex-grow">
								<div class="flex-row flex-grow">
									<div class="flex-column dtech-pad-right-5"
										ng-if="member.photoInfo">
										<div class="avatar-container dtech-avatar-round-{{dtechUserImageSize}}rem" >
											<span>
<!--
												<div class="dtech-ooo-item-container">
													<div class="dtech-ooo-item"
														ng-class="{'dtech-ooo-indicator': member.photoInfo.isOoO==true}" />
												</div>
-->
												<div ng-if="member.photoInfo.hasPhoto==true"
														class="avatar soloAvatar dtech-avatar-bg-color-transparent">
														<div  class="sub-avatar dtech-avatar-bg-color" 
															style="{{member.photoInfo.photo}}">
														</div>
												</div>

												<div ng-if="member.photoInfo.hasPhoto!=true"
													class="dtech-avatar-initials-bg-color dtech-avatar-round-{{dtechUserImageSize}}rem">
													{{member.photoInfo.initials}}
												</div>
												<div class="dtech-ooo-item-container">
													<div class="dtech-ooo-item-13" ng-show = "member.photoInfo.isOoO==true">
														<img src="x_153465_discovert.OutOfOffice13.svg" />
													</div>
												</div>

											</span>
										</div>
										<div> <!-- place holder to move div above up --> </div>
									</div>
									<span class="flex-column flex-grow">
										<span ng-if="!member.value"
											class="dtech-modal-widget-text-black-bold">
											(${gs.getMessage("Empty")})
										</span>
										<span ng-if="member.value"
											class="dtech-modal-widget-text-black-bold">
											{{member.display_value}}
										</span>
										<span >
											<span class="dtech-sonic-silver-text-color">{{member.label}}</span>
										</span>								
									</span>	
									<span class="flex-column">
										<div class="dtech-popover-btn"> <!-- when this layer isn't here, the div below gets a role of button -->
											<div ng-if="d.chatEnabled()"
													ng-click="d.openChat($event, member)" >
												<img src="x_153465_discovert.Teams24.svg" title="${gs.getMessage('Tasker - Open Chat')}"/>
<!--
						<a target="_blank" href="https://teams.microsoft.com/l/chat/0/0?users={{dtechParamObject.email}}">${gs.getMessage("Tasker - Open Chat")}</a>
						<a target="_blank" href="https://teams.microsoft.com/l/chat/0/0?users=mmccune@discovertechnologies.com">${gs.getMessage("Tasker - Open Chat")}</a>
-->
											</div>
										</div>
									</span>							
								</div>									
							</div>
						</li>
						<li ng-if="d.chatEnabled()">
							<span class="flex-row dtech-border-top-2px-light">
								<span class="flex-column flex-grow"/>
								<span class="flex-column dtech-pad-right-10 dtech-pad-top-10">
									<div class="dtech-popover-btn"> <!-- when this layer isn't here, the div below gets a role of button -->
										<div ng-if="d.chatEnabled()"
												ng-click="d.openChatAll($event)" >
											<img src="x_153465_discovert.TeamsChatAll24.svg" title="${gs.getMessage('Chat with all task members')}"/>
										</div>
									</div>
								</span>
							</span>
						</li>						
					</ul>
				</div>
			</div>
		</div>
	</script>
</span>
]]></xml>
    </sys_ui_macro>
</record_update>
