        <description>2.8 Fix Script to populate OU ancestors on the OU</description>
        <name>2.8.1 - Fix Script - OU Ancestors</name>
        <record_for_rollback>true</record_for_rollback>
        <script><![CDATA[var grOU = new GlideRecord('x_153465_discovert_discover_office_hierarchy');
grOU.query();
while(grOU.next()){
  var parentId = grOU.getValue("parent");
  var ancestors = new OrganizationalScripts().getAncestors(parentId);
  grOU.u_all_ancestors_organizations = ancestors;
  grOU.update();
}]]></script>
