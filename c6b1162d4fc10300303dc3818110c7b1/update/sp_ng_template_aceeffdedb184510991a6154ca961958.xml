        <template><![CDATA[<div id="task-info-tooltip-template" class="container modal-content task-info-tooltip-content">
  <div class="row modal-header {{c.data.popOverRecord[item.sys_id].state_converted}}">
    <h5 class="col-sm-12 modal-title modal-title-manual">{{c.data.popOverRecord[item.sys_id].title}}</h5>
  </div>
  <div class="modal-body task-info-tooltip-body">
    <div class="row">
      <div class="col-sm-12 ">
        <div class="banners">
          <!-- TODO - Mark McCune - need to create badges for the request fields if we want to use this style going forward
				since 3.0 may not have this styling and RJ is not familiar with creating badges, left this for technical debt clean up see TDC in this file-->
          
          <!-- TDC - Status is converted to state to use state badge of 'Work in Progress' for in progress and badge of 'Completed' for 'Completed' -->
          <div class="badge {{c.data.popOverRecord[item.sys_id].state_converted}}" ng-show="c.data.popOverRecord[item.sys_id].state_converted.length > 0">
        		<span title="State: {{c.data.popOverRecord[item.sys_id].u_status}}">{{c.data.popOverRecord[item.sys_id].u_status}}</span>
          </div>
          <!-- TDC - tasker type class looks good for this type too -->
          <div class="taskertype" ng-show="c.data.popOverRecord[item.sys_id].u_request_type.length > 0">
        		<span title="Request Type: {{c.data.popOverRecord[item.sys_id].u_request_type}}">{{c.data.popOverRecord[item.sys_id].u_request_type}}</span>
          </div>
          <!-- TDC - using restricted badge for color of rejected request-->
          <div class="badge restricted-group" ng-show="c.data.popOverRecord[item.sys_id].u_response=='Rejected'"> 
            <span title="Response: {{c.data.popOverRecord[item.sys_id].u_response}}">{{c.data.popOverRecord[item.sys_id].u_response}}</span>
          </div>
          <!-- TDC - using Accepted badge for color of Approved request-->
          <div class="badge Accepted" ng-show="c.data.popOverRecord[item.sys_id].u_response=='Approved'"> 
            <span title="Response: {{c.data.popOverRecord[item.sys_id].u_response}}">{{c.data.popOverRecord[item.sys_id].u_response}}</span>
          </div>
        </div>
      </div>
    </div>
    <div class="row">
      <div class="col-sm-12 ">
        <label for="u_request_comments">
          <h4>${Request Comments}:</h4>
        </label>
        <p id="request_comments_html" class="task-info-tooltip-objective" ng-bind-html="c.data.popOverRecord[item.sys_id].request_comments_html"></p>
      </div>
    </div>
    <div class="row" ng-show="c.data.popOverRecord[item.sys_id].u_response_comments.length > 0">
      <div class="col-sm-12 ">
        <label for="u_response_comments">
          <h4>${Response Comments}:</h4>
        </label>
        <p id="response_comments_html" class="task-info-tooltip-objective" ng-bind-html="c.data.popOverRecord[item.sys_id].response_comments_html"></p>
      </div>
    </div>    
  </div>
</div>]]></template>
    </sp_ng_template>
</record_update>
