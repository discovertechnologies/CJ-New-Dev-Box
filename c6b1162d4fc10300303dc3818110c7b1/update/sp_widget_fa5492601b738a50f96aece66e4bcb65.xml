        <template><![CDATA[<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no, viewport-fit=cover"/>
<meta name="description" content="A Gantt chart that supports zooming into the timeline."/>
<title>Gantt chart</title>
<style>
 #sample {
   position: relative;
   width: 100%;
   height: 100%;
 }
 #myTasksDiv, #myGanttDiv {
   height: 400px;
 }
</style>
</head>

<body>

<!-- Start of GoJS sample code -->
<script src="/scripts/libs/gojs/1.7/gojs.js"></script>
<div id="allSampleContent" class="p-4 w-full">
 <div id="sample">
   <div style="width: 100%; display: flex; justify-content: space-between; border: solid 1px black">
     <div id="myTasksDiv" style="width: 280px; margin-right: 2px; border-right: solid 1px black"></div>
     <div id="myGanttDiv" style="flex-grow: 1; height: 400px"></div>
   </div>
   <div id="slider">
     <label>Spacing:</label>
     <input id="widthSlider" type="range" min="8" max="24" value="12" oninput="rescale()"/> <button id="showInProgressBtn">Show In-Progress Tasks</button>
   </div>
   <div id="testRunnerDiv" style="margin-top: 10px; margin-bottom: 10px; border: 1px solid #ccc; padding: 10px;">
     <label for="selectTestScript">Select Test Suite:</label>
     <select id="selectTestScript" style="margin-right: 10px;">
       <option value="runGanttDataValidationTests">Gantt Data Validation Tests</option>
       <option value="runHighlightDependencyTest">Critical Dependency Highlighting</option>
       <option value="runNewFeatureTest">New Feature Test</option>
     </select>
     <button id="runSelectedTestBtn">Run Selected Test</button>
   </div>
   <p>This sample demonstrates a simple Gantt chart.</p>
   <p>The current model in JSON format, automatically updated as the diagram is modified:</p>
   <textarea id="mySavedModel" style="width:100%;height:250px"></textarea>
 </div>
 <script src="gantt-data.js"></script>
 <script src="gantt-logic.js"></script>
</div>
<!-- End of GoJS sample code -->
</div>
</body>
</html>
