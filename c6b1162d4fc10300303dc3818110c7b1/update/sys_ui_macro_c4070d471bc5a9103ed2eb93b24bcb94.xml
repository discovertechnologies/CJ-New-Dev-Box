        <sys_mod_count>106</sys_mod_count>
        <sys_name>dtechUser.html</sys_name>
        <sys_package display_value="Tasker" source="x_153465_discovert">c6b1162d4fc10300303dc3818110c7b1</sys_package>
        <sys_policy/>
        <sys_replace_on_upgrade>false</sys_replace_on_upgrade>
        <sys_scope display_value="Tasker">c6b1162d4fc10300303dc3818110c7b1</sys_scope>
        <sys_update_name>sys_ui_macro_c4070d471bc5a9103ed2eb93b24bcb94</sys_update_name>
        <sys_updated_by>mmccune</sys_updated_by>
        <sys_updated_on>2023-09-11 22:01:32</sys_updated_on>
        <xml><![CDATA[<div role="button"
	 ng-click="d.openModal($event);d.leaveTooltip();">
	<div class="flex-row"
		 ng-mouseenter="d.showProfile($event);" 
		 ng-mouseleave="d.parentMouseLeave();" 

		 uib-popover-template="'template.html'"
		 popover-trigger="none"
		 popover-is-open="dtechUserToolTipOpen"
		 popover-placement="auto"
		 popover-animation="true"
		 popover-class="dtech-user-profile dtech-popover-container-avatar dtech-user-profile-open" 
		 popover-append-to-body="dtechIsModal!=true"
		 popover-popup-delay="{{d.popoverDelay}}">
		<div class="avatar-container dtech-avatar-round-{{dtechUserImageSize}}rem" >
			<span>		
				<div class="dtech-ooo-item-container">
					<div class="dtech-ooo-item"
						 ng-class="{'dtech-ooo-indicator': dtechUserPhotoInfo.isOoO==true}" />
				</div>	

				<div class="avatar soloAvatar dtech-avatar-bg-color-transparent">
					<div  class="pointer sub-avatar dtech-avatar-bg-color" style="{{d.setStyleBackgroundImage(dtechUserPhotoInfo.photo)}}"/>

				</div>
			</span>	
		</div>		
		<div class="dtech-pad-left-10 text-nowrap" >
			<a class="dtech-avatar-link">{{dtechParamObject.name}}</a>
		</div>
	</div>	
	<script type="text/ng-template" id="template.html">
		<div ng-mouseenter="d.enterTooltip();"
			 ng-mouseleave="d.leaveTooltip();"
			 ng-init="d.initTooltip();">
			<div class="row">
				<div class="col-md-12 text-center">
					<div class="row">
						<div class="avatar-container dtech-avatar-round-64rem">
							<div class="dtech-ooo-item-container">
								<div class="dtech-ooo-item"
									 ng-class="{'dtech-ooo-indicator': dtechUserPhotoInfo.isOoO==true}" />
							</div>	

							<div class="avatar soloAvatar dtech-avatar-bg-color-transparent">
								<div  class="sub-avatar dtech-avatar-bg-color" style="{{dtechParamObject.photoBackground}}">
								</div>
							</div>
						</div>
					</div>
				</div>
			</div>
			<div ng-if="d.isSpinnerShown">
				<div class="dtech-popover-list-spinner-content">
					<fa name="spinner" spin="true"></fa>
				</div>
			</div>
			<div ng-if="!d.isSpinnerShown">
				<div class="row">
					<div class="col-md-12 text-center dtech-avatar-text-standard-16 dtech-margin-top-5px">{{dtechParamObject.name}}</div>
				</div>
				<div class="row">
					<div class="col-md-12 text-center">
						<span class="dtech-avatar-link" ng-click="d.openUserProfileModal($event)">${gs.getMessage("Tasker - Open Profile Page")}</span>
					</div>
				</div>
				<div class="row">
					<div class="col-md-12 text-center dtech-margin-top-5px">
						<button ng-if="d.chatEnabled()" ng-click="d.openColabChatConversation()" type="button"
								class="btn btn-primary send-message"><span class="glyphicon glyphicon-comment pad-right"></span>${gs.getMessage("Tasker - Open Chat")}</button>
					</div>
				</div>
				<div class="row">
					<div ng-if="dtechParamObject.email" class="col-md-12 text-left dtech-pad-top-10">
						<img src="Mail16.svg" title="${gs.getMessage('Send Mail')}"
							 alt="${gs.getMessage('Send Mail')}" class="dtech-pad-left-10 dtech-pad-right-10"/>
						<span class="dtech-avatar-text-standard-16" ng-click="d.sendMailTo()">{{dtechParamObject.email}}</span>
					</div>
				</div>
				<div class="row">
					<div ng-if="dtechParamObject.businessPhone" class="col-md-12 text-left dtech-margin-top-5px">
						<img src="BusinessPhone16.svg" title=""
							 alt="" class="dtech-pad-left-10 dtech-pad-right-10"/>
						<span class="dtech-avatar-text-standard-16">{{dtechParamObject.businessPhone}}</span>
					</div>
				</div>
				<div class="row">
					<div ng-if="dtechParamObject.mobilePhone" class="col-md-12 text-left dtech-margin-top-5px">
						<img src="Phone16.svg" title=""
							 alt="" class="dtech-pad-left-10 dtech-pad-right-10"/>
						<span class="dtech-avatar-text-standard-16">{{dtechParamObject.mobilePhone}}</span>
					</div>
				</div>
			</div>
			<div class="dtech-footer-row-sticky">
				<div class="col-md-6 dtech-pad-left-0 text-left dtech-avatar-text-standard-14 dtech-opacity-50">{{dtechParamObject.location}}</div>
				<div class="col-md-6 dtech-pad-right-0 text-right dtech-avatar-text-standard-14 dtech-opacity-50">{{dtechParamObject.time_zone}}
				</div>
			</div>
		</div>
	</script>
</div>]]></xml>
    </sys_ui_macro>
</record_update>
