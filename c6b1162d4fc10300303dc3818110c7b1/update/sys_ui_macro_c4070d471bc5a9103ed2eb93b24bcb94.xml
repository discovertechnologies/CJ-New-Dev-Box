<?xml version="1.0" encoding="UTF-8"?><record_update table="sys_ui_macro">
    <sys_ui_macro action="INSERT_OR_UPDATE">
        <active>true</active>
        <category>general</category>
        <description>HTML Template used in the Angular Provider Directive dtechUser&#13;
This directive allows us to put the same style on the user anywhere we want to use it.  &#13;
It can put the picture on the screen in 16,24,32,64 rem formats using the dtechUser.size attribute&#13;
It will show out of office for the user if the OoO flag is set&#13;
It also handles hovering over the user and displaying appropriate info in the hover&#13;
&#13;
2.8.5 | 2023-09-11 | mmcc | DFCT0012116 - List / form bifold view should NOT crop the "Reopen Comments Modal". Should display properly &#13;
Changed popover-placement to use "auto"&#13;
2.8.1 | 2023-05-11 | mmcc | STRY0139742 - Increase delaying when hover directives open&#13;
Updated popover-popup-delay to use a var - "{{d.popoverDelay}}"&#13;
Added ng-init="d.initTooltip();" to first &lt;div&gt; of template-duration.html&#13;
2.8.1 | 2023-04-07 | raj | STRY0136617 - Added check for sidebar on and enable chat&#13;
2.8.1 | 2023-03-25 | raj  | STRY0133254 - Org Hierarchy- Profile Picture/ Avatar Control- Relabel "Open Contact Page" to "Open Profile Page"&#13;
2.8.1 | 2023-01-30 | raj | STRY0135276 - POC - Data Table - Response Comment Update - User Profile Directive - move user profile scripts from TaskWidgetData into UerInfoScitps </description>
        <media_type/>
        <name>dtechUser.html</name>
        <scoped_name>x_153465_discovert_dtechUser.html</scoped_name>
        <sys_class_name>sys_ui_macro</sys_class_name>
        <sys_created_by>rjoy</sys_created_by>
        <sys_created_on>2023-02-20 18:00:09</sys_created_on>
        <sys_id>c4070d471bc5a9103ed2eb93b24bcb94</sys_id>
        <sys_mod_count>157</sys_mod_count>
        <sys_name>dtechUser.html</sys_name>
        <sys_package display_value="Tasker" source="x_153465_discovert">c6b1162d4fc10300303dc3818110c7b1</sys_package>
        <sys_policy/>
        <sys_scope display_value="Tasker">c6b1162d4fc10300303dc3818110c7b1</sys_scope>
        <sys_update_name>sys_ui_macro_c4070d471bc5a9103ed2eb93b24bcb94</sys_update_name>
        <sys_updated_by>rjoy</sys_updated_by>
        <sys_updated_on>2024-04-24 04:37:16</sys_updated_on>
        <xml><![CDATA[<span ng-click="d.openUserProfileModal($event);d.leaveTooltip()">
	 <span ng-mouseenter="d.showProfile();"
	 		ng-mouseleave="d.parentMouseLeave();"
			role="button" >

		<span uib-popover-template="'template.html'"
				popover-trigger="none"
				popover-is-open="dtechUserToolTipOpen"
				popover-placement="{{dtechPopoverPlacement}}"
				popover-animation="true"
				popover-class="dtech-user-profile dtech-popover-container-avatar dtech-user-profile-open" 
				popover-append-to-body="dtechIsModal!=true"
				popover-popup-delay="{{d.popoverDelay}}">
			<span class="text-nowrap"
				ng-class="d.getBtnClass()">
				<div class="avatar-container dtech-avatar-round-{{dtechUserImageSize}}rem" >
<!-- TODO - change this to show initials instead of the no photo graphic -->
					<div class="avatar soloAvatar dtech-avatar-bg-color-transparent">
						<div  class="pointer sub-avatar dtech-avatar-bg-color" style="{{d.setStyleBackgroundImage(dtechUserPhotoInfo.photo)}}"/>

					</div>
					<div class="dtech-ooo-item-container">
						<div class="dtech-ooo-item-13" ng-show = "dtechUserPhotoInfo.isOoO==true">
							<img src="x_153465_discovert.OutOfOffice13.svg" />
						</div>
					</div>	
				</div>		
				<div class="dtech-pad-left-10 text-nowrap" >
					{{dtechParamObject.name}}
				</div>
			</span>
		</span>
	</span>
	<script type="text/ng-template" id="template.html">
		<div ng-mouseenter="d.enterTooltip();"
			 ng-mouseleave="d.leaveTooltip();"
			 ng-init="d.initTooltip();"
			 class="flex-column">
			<div class="flex-row align-stretch dtech-pad-bottom-30">
				<div class="flex-column dtech-popover-btn">
					<div class="avatar-container dtech-avatar-round-64rem"
						ng-click="d.openUserProfileModal($event)" title="${gs.getMessage('Tasker - Open Profile Page')}">
						<div class="avatar soloAvatar dtech-avatar-bg-color-transparent">
							<div  class="sub-avatar dtech-avatar-bg-color" style="{{dtechParamObject.photoBackground}}">
							</div>
						</div>
						<div class="dtech-ooo-item-container">
							<div class="dtech-ooo-item-24" ng-show = "dtechUserPhotoInfo.isOoO==true">
								<img src="x_153465_discovert.OutOfOffice24.svg" />
							</div>
						</div>
					</div>
				</div>
				<div class="flex-column flex-grow dtech-pad-left-20">
					<div class="flex-row">
						<div class="flex-column flex-grow"
							ng-click="d.openUserProfileModal($event)" title="${gs.getMessage('Tasker - Open Profile Page')}">
							<div ng-if="dtechParamObject.loaded==true">
								<div class="flex-row">
									<div class="dtech-popover-lnk">{{dtechParamObject.name}}</div>
								</div>
								<div class="flex-row">
									<div class="dtech-popover-lnk">{{dtechParamObject.title}}</div>
								</div>
								<div class="flex-row" >
<!-- TODO - add call to open profile page in out of office tab -->
									<a class="dtech-ooo-list-message-item dtech-ooo-message-text"> ${gs.getMessage('Out of Office')} </a>
								</div>
							</div>
						</div>
					</div>
				</div>
			</div>
			<div class="flex-row justify-center">
				<div class="dtech-pad-right-15">
					<div class="dtech-popover-btn"> <!-- when this layer isn't here, the div below gets a role of button -->
						<div ng-if="d.chatEnabled()"
								ng-click="d.openChat()" >
							<img src="x_153465_discovert.Teams24.svg" title="${gs.getMessage('Tasker - Open Chat')}"/>
<!--
						<a target="_blank" href="https://teams.microsoft.com/l/chat/0/0?users={{dtechParamObject.email}}">${gs.getMessage("Tasker - Open Chat")}</a>
						<a target="_blank" href="https://teams.microsoft.com/l/chat/0/0?users=mmccune@discovertechnologies.com">${gs.getMessage("Tasker - Open Chat")}</a>
-->
						</div>
					</div>
				</div>
				<div class="dtech-pad-left-15">
					<div class="dtech-popover-btn"> <!-- when this layer isn't here, the div below gets a role of button -->
						<div ng-if="d.chatEnabled()" class="dtech-popover-btn"
								ng-click="d.openColabChatConversation()" >
							<img src="x_153465_discovert.Chat24.svg" title="${gs.getMessage('Tasker - Open Chat')}"/>
						</div>
					</div>
				</div>
			</div>					
			<div class="flex-row" 
				ng-if="dtechParamObject.loaded!=true">
				<div class="dtech-popover-list-spinner-content">
					<fa name="spinner" spin="true"></fa>
				</div>
			</div>
			<div class="flex-row dtech-user-profile-divider" ng-if="dtechParamObject.loaded==true"/>
			<div class="flex-row" 
				ng-if="dtechParamObject.loaded==true">
				<div class="flex-column">
					<div class="flex-row font-bold">
						${gs.getMessage('Contact')}
					</div>
					<div class="flex-row">
						<div ng-if="dtechParamObject.email" class="text-left dtech-pad-top-10">
							<img src="Mail16.svg" title="${gs.getMessage('Send Mail')}"
								alt="${gs.getMessage('Send Mail')}" class="dtech-pad-left-10 dtech-pad-right-10"/>
							<span class="dtech-popover-lnk" ng-click="d.sendMailTo()">{{dtechParamObject.email}}</span>
						</div>
					</div>
					<div class="flex-row">
						<div ng-if="dtechParamObject.businessPhone" class="text-left dtech-pad-top-10">
							<img src="BusinessPhone16.svg" title=""
								alt="" class="dtech-pad-left-10 dtech-pad-right-10"/>
							<span class="dtech-popover-lnk">{{dtechParamObject.businessPhone}}</span>
						</div>
					</div>
					<div class="flex-row">
						<div ng-if="dtechParamObject.mobilePhone" class="text-left dtech-pad-top-10">
							<img src="Phone16.svg" title=""
								alt="" class="dtech-pad-left-10 dtech-pad-right-10"/>
							<span class="dtech-popover-lnk">{{dtechParamObject.mobilePhone}}</span>
						</div>
					</div>
				</div>
			</div>
			<div class="dtech-footer-row-sticky">
				<div class="col-md-6 dtech-pad-left-0 text-left dtech-avatar-text-standard-14 dtech-opacity-50">{{dtechParamObject.location}}</div>
				<div class="col-md-6 dtech-pad-right-0 text-right dtech-avatar-text-standard-14 dtech-opacity-50">{{dtechParamObject.time_zone}}
				</div>
			</div>
		</div>
	</script>
</span>]]></xml>
    </sys_ui_macro>
</record_update>
