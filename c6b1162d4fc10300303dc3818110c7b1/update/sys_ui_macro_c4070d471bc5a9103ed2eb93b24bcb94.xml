<?xml version="1.0" encoding="UTF-8"?><record_update table="sys_ui_macro">
    <sys_ui_macro action="INSERT_OR_UPDATE">
        <active>true</active>
        <category>general</category>
        <description>HTML Template used in the Angular Provider Directive dtechUser&#13;
This directive allows us to put the same style on the user anywhere we want to use it.  &#13;
It can put the picture on the screen in 16,24,32,64 rem formats using the dtechUser.size attribute&#13;
It will show out of office for the user if the OoO flag is set&#13;
It also handles hovering over the user and displaying appropriate info in the hover&#13;
&#13;
2.8.5 | 2023-09-11 | mmcc | DFCT0012116 - List / form bifold view should NOT crop the "Reopen Comments Modal". Should display properly &#13;
Changed popover-placement to use "auto"&#13;
2.8.1 | 2023-05-11 | mmcc | STRY0139742 - Increase delaying when hover directives open&#13;
Updated popover-popup-delay to use a var - "{{d.popoverDelay}}"&#13;
Added ng-init="d.initTooltip();" to first &lt;div&gt; of template-duration.html&#13;
2.8.1 | 2023-04-07 | raj | STRY0136617 - Added check for sidebar on and enable chat&#13;
2.8.1 | 2023-03-25 | raj  | STRY0133254 - Org Hierarchy- Profile Picture/ Avatar Control- Relabel "Open Contact Page" to "Open Profile Page"&#13;
2.8.1 | 2023-01-30 | raj | STRY0135276 - POC - Data Table - Response Comment Update - User Profile Directive - move user profile scripts from TaskWidgetData into UerInfoScitps </description>
        <media_type/>
        <name>dtechUser.html</name>
        <scoped_name>x_153465_discovert_dtechUser.html</scoped_name>
        <sys_class_name>sys_ui_macro</sys_class_name>
        <sys_created_by>rjoy</sys_created_by>
        <sys_created_on>2023-02-20 18:00:09</sys_created_on>
        <sys_customer_update>false</sys_customer_update>
