        <template><![CDATA[<div class="dtech-modal-widget-body">
  <div class="dtech-text-center">
    <img src="Warning64.svg"/>
  </div>

  <div class="dtech-text-center">
    <h1 class="text-uppercase">{{data.msgWarning}}!</h1>
  </div>

  <div class="dtech-text-center dtech-standard-text-color">
    <span>
      {{data.msgBody3}}
    </span>
  </div>
  <br>
  
  <div class="dtech-text-center dtech-standard-text-color">
    <span>
      {{data.msgBody4}}
    </span>
  </div>
  <br>
  
  <!-- STRY0125927 -->
  <div ng-if="data.draftDescendantsCount>0">
    <div class="dtech-text-center dtech-standard-text-color">
      <span>
        {{data.msgDraftCount}}
      </span>
    </div>
    <br>
    <div class="dtech-text-center">
      <img src="InfoRound24.svg"/>
      <span class="dtech-subtasks-also-deleted">{{data.msgDraftInfo}}</span>
    </div>
    <br>
  </div>
  
  <div class="dtech-text-center dtech-standard-text-color">
    <span>
      {{data.msgBody5}}
    </span>
  </div>
  <br>
  
</div>
<div id="footer" class="dtech-modal-widget-footer dtech-box">

  <button id="cancel" class="btn btn-default dtech-max-width-fit-content"
          type="button" title="{{data.cancelButtonText}}"
          ng-click="c.onCancel()" data-dismiss="modal">{{data.cancelButtonText}}
  </button>

  <button id="continue" class="btn btn-primary dtech-max-width-fit-content dtech-push-right"
          type="button" title="{{data.continueButtonTitle}}"
          ng-click="c.onContinue();">{{data.continueButtonText}}
  </button>
</div>
]]></template>
