        <template><![CDATA[<ul class="typeahead-popup dropdown-menu" aria-label="{{::$parent.c.options.title}} {{::$parent.c.data.searchSuggestionsMsg}}" ng-show="isOpen() && !moveInProgress" ng-style="{top: position().top+'px', left: position().left+'px'}" role="listbox" aria-hidden="{{!isOpen()}}">
    <li role='option' aria-hidden='true' style='display: none'></li>    
