        <category>custom</category>
        <client_script><![CDATA[function($scope, $rootScope, dtBreadcrumbs, spUtil) {
	var c = this;
	c.expanded = !spUtil.isMobile();
	c.expand = function() {
		c.expanded = true;
	};	
		
	c.breadcrumbs = [];
	     
	var newCrumb = {
		label: $scope.page.title,
		url: location.href
	};

	// because of strange SNOW routing behavior with new item page when discarded,
	// the provider doesn't know it is going to home page so crumbs do not get cleared
	// also we don't want the user navigating back to new item form that they didn't save
	if (newCrumb.label !== 'New Item') {
		dtBreadcrumbs.insert([newCrumb]);
	} else {
		c.breadcrumbs.push(newCrumb);
	}
	// if they aren't on new item page, they get normal breadcrumbs
	// otherwise they get the new item crumb but it is not saved in sessionStorage
	c.breadcrumbs = dtBreadcrumbs.get().concat(c.breadcrumbs);
	
	// if page needs custom breadcrumbs
	var deregister = $rootScope.$on('sp.update.breadcrumbs', function(event, list) {

		if (list != undefined) {
			list.forEach(function(crumb) {
				if (crumb.url === '#')
					crumb.url = location.href;
			})
		}
		
		//dtBreadcrumbs.pop();
		dtBreadcrumbs.insert(list);
		c.breadcrumbs = dtBreadcrumbs.get();
	});
	// clean up listener
	$scope.$on('$destroy', deregister);
}]]></client_script>
        <controller_as>c</controller_as>
