        <template><![CDATA[<ul class="nav nav-pills nav-sm" aria-label="${Page breadcrumbs}" role="navigation">
  <li>
    <span>
      <a ng-href="?id={{portal.homepage_dv}}">${Home}</a>
      <i aria-hidden="true" class="fa fa-chevron-right"></i>
    </span>
  </li>
  <li ng-if="!c.expanded &amp;&amp; c.breadcrumbs &amp;&amp; c.breadcrumbs.length > 2">
    <span>
      <a ng-click="c.expand()"><i class="fa fa-ellipsis-h" aria-hidden="true"></i></a>
      <i aria-hidden="true" class="fa fa-chevron-right"></i>
    </span>
  </li>
  <li ng-if="!c.breadcrumbs"><span><a style="display: inline;" href>{{page.title}}</a></span></li>
  <li ng-if="c.expanded || ((c.breadcrumbs.length > 2  &amp;&amp; $index > c.breadcrumbs.length-3) || (c.breadcrumbs.length <= 2))" >
    <span ng-repeat="item in c.breadcrumbs track by $index">
      <a ng-if="!$last" ng-href="{{item.url}}">{{item.label}}</a>
      <a id="last" ng-if="$last" ng-click="refresh();">{{item.label}}</a>
      <i aria-hidden="true" ng-if="!$last" class="fa fa-chevron-right"></i>
    </span>
  </li>
</ul>]]></template>
