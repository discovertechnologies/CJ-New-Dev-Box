(function executeRule(current, previous /*null when async*/) {

	// RAJ 2018-02-20 - STRY0010804 - Tasker Process Definition - if Tasking Authoirty changes and the new tasking authority is internal, Update Primary Office to be the same as the Tasking Authority
	
	var grChildren = new GlideRecordSecure('x_153465_discovert_route_tasks');
	grChildren.addQuery('parent', current.sys_id);
	grChildren.query();

	while (grChildren.next()){
		// Update the Tasking Authority on all children
		grChildren.tasking_authority= current.tasking_authority;
		grChildren.update();
	}
})(current, previous);]]></script>
