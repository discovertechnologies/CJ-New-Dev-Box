        <template><![CDATA[<div id="task-info-tooltip-template" class="container modal-content task-info-tooltip-content">
  <div class="row modal-header {{c.data.popOverRecord[item.sys_id].state}}">
    <h5 class="col-sm-12 modal-title modal-title-manual">{{c.data.popOverRecord[item.sys_id].title}}</h5>
  </div>
  <div class="modal-body task-info-tooltip-body">
    <div class="row">
      <div class="col-sm-12 ">
        <!-- Need to look at how to adjust this to support any table -->
<!--        
        <p class="badge rejected">{{c.data.popOverRecord[item.sys_id].classification}}</p>
        <p class="badge {{c.data.popOverRecord[item.sys_id].status}}">{{c.data.popOverRecord[item.sys_id].status}}</p>
        <p class="taskertype">{{c.data.popOverRecord[item.sys_id].taskType}}</p>

-->
        <div class="banners">
          <div class="badge taskform-classification-banner-{{c.data.popOverRecord[item.sys_id].classification}}" ng-show="c.data.popOverRecord[item.sys_id].classification.length > 0"> 
            <span title="Classification: {{c.data.popOverRecord[item.sys_id].classification}}">{{c.data.popOverRecord[item.sys_id].classification}}</span>
          </div>
          <div class="badge restricted-group" ng-show="c.data.popOverRecord[item.sys_id].assignment_group.length > 0"> 
            <span title="Restricted Group: {{c.data.popOverRecord[item.sys_id].assignment_group}}">{{c.data.popOverRecord[item.sys_id].assignment_group}}</span>
          </div>
          <div class="badge {{c.data.popOverRecord[item.sys_id].status}}" ng-show="c.data.popOverRecord[item.sys_id].status.length > 0">
        		<span title="Status: {{c.data.popOverRecord[item.sys_id].status}}">{{c.data.popOverRecord[item.sys_id].status}}</span>
          </div>
          <div class="taskertype" ng-show="c.data.popOverRecord[item.sys_id].taskType.length > 0">
        		<span title="Task Type: {{c.data.popOverRecord[item.sys_id].taskType}}">{{c.data.popOverRecord[item.sys_id].taskType}}</span>
          </div>
        </div>
      </div>
    </div>
    <div class="row">
      <div class="col-sm-12 ">
        <label for="objective">
          <h4>${Objective}:</h4>
        </label>
        <p id="objective" class="task-info-tooltip-objective" ng-bind-html="c.data.popOverRecord[item.sys_id].objective"></p>
      </div>
    </div>
  </div>
</div>]]></template>
    </sp_ng_template>
