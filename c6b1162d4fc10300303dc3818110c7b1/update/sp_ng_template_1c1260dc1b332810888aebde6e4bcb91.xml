        <template><![CDATA[<div id="task-info-tooltip-template" class="container modal-content task-info-tooltip-content">
  <div class="row modal-header " 
       ng-class="{unassigned: c.data.popOverRecord[item.sys_id].state == 'Unassigned', 
                 assigned: c.data.popOverRecord[item.sys_id].state == 'Assigned', 
                 accepted: c.data.popOverRecord[item.sys_id].state == 'Accepted', 
                 rejected: c.data.popOverRecord[item.sys_id].state == 'Rejected', 
                 workscheduled : c.data.popOverRecord[item.sys_id].state == 'Work Scheduled', 
                 rework : c.data.popOverRecord[item.sys_id].state == 'Rework', 
                 workinprogress : c.data.popOverRecord[item.sys_id].state == 'Work in Progress', 
                 inreview : c.data.popOverRecord[item.sys_id].state == 'In Review', 
                 completed : c.data.popOverRecord[item.sys_id].state == 'Completed', 
                 cancelled : c.data.popOverRecord[item.sys_id].state == 'Cancelled', 
                 waiting : c.data.popOverRecord[item.sys_id].state == 'Waiting', 
                 closedincomplete : c.data.popOverRecord[item.sys_id].state == 'Closed Incomplete'}">
    <h5 class="col-sm-12 modal-title modal-title-manual">{{c.data.popOverRecord[item.sys_id].title}}</h5>
  </div>
  <div class="modal-body task-info-tooltip-body">
    <div class="row">
      <div class="col-sm-12">
        <p class="badge rejected">{{c.data.popOverRecord[item.sys_id].classification}}</p>
        <p class="badge assigned">{{c.data.popOverRecord[item.sys_id].status}}</p>
        <p class="taskertype">{{c.data.popOverRecord[item.sys_id].taskType}}</p>
      </div>
    </div>
    <div class="row">
      <div class="col-sm-12 ">
        <label for="objective">
          <h4>${Objective}:</h4>
        </label>
        <p id="objective" class="task-info-tooltip-objective" ng-bind-html="c.data.popOverRecord[item.sys_id].objective"></p>
      </div>
    </div>
  </div>
</div>]]></template>
    </sp_ng_template>
</record_update>
