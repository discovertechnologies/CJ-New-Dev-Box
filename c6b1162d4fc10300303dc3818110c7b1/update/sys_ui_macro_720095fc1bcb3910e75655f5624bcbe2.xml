        <sys_mod_count>20</sys_mod_count>
        <sys_name>dtechWarning.html</sys_name>
        <sys_package display_value="Tasker" source="x_153465_discovert">c6b1162d4fc10300303dc3818110c7b1</sys_package>
        <sys_policy/>
        <sys_scope display_value="Tasker">c6b1162d4fc10300303dc3818110c7b1</sys_scope>
        <sys_update_name>sys_ui_macro_720095fc1bcb3910e75655f5624bcbe2</sys_update_name>
        <sys_updated_by>rjoy</sys_updated_by>
        <sys_updated_on>2023-12-15 20:33:08</sys_updated_on>
        <xml><![CDATA[<span role="button"
	 ng-click="d.openModal($event);d.leaveTooltip();"> 
	<span ng-mouseenter="d.showWarning();" 
		 ng-mouseleave="d.parentMouseLeave();">

		<span uib-popover-template="'dtech-popover-warning.html'"
			 popover-trigger="none"
			 popover-is-open="dtechToolTipOpen"
			 popover-placement="{{dtechPopoverPlacement}}"
			 popover-animation="true"
			 popover-class="dtech-popover-container-box-shadow dtech-width-400px" 
			 popover-append-to-body="dtechIsModal==false"
			 popover-popup-delay="{{d.popoverDelay}}">
			<span class="pointer" >
				<img src="x_153465_discovert.NodeWarning_Hover24.svg"/>
			</span>
		</span>
	</span>
	<script type="text/ng-template" id="dtech-popover-warning.html">
		<div ng-mouseenter="d.enterTooltip();"
			 ng-mouseleave="d.leaveTooltip();"
			 ng-init="d.initTooltip();"
			 class="flex-column">
			<div ng-if="dtechWarningObject.warning.waitStatewithNoSubtasks">
				<div class="flex-row dtech-pad-top-10 dtech-pad-bottom-10">
					<img class="dtech-pad-right-10"
						src="x_153465_discovert.Warning16.svg"/>
					<span class="dtech-pad-right-10">
						<span class="dtech-pad-right-10">
							{{dtechWarningObject.warning.waitStateNoSubtasks_msg}}
						</span>
					</span>
					<span class="flex-column justify-end text-nowrap dtech-pad-left-10 dtech-avatar-link"
							ng-click="d.openModal($event)">
						${gs.getMessage("Show Me...")}
					</span>
				</div>
			</div>
			<div ng-if="dtechWarningObject.u_warning_projected_due_date_before_child.display_value=='true'">
				<div class="flex-row dtech-pad-top-10 dtech-pad-bottom-10">
					<img class="dtech-pad-right-10"
						src="x_153465_discovert.Warning16.svg"/>
					<span class="dtech-pad-right-10">
						<span class="dtech-pad-right-10">
							{{dtechWarningObject.warning.parentBeforeChild_msg}}
						</span>
					</span>
					<span class="flex-column justify-end text-nowrap dtech-pad-left-10 dtech-avatar-link"
							ng-click="d.openModal($event)">
						${gs.getMessage("Show Me...")}
					</span>
				</div>
			</div>
			<div ng-if="dtechWarningObject.u_warning_projected_due_date_after_parent.display_value=='true'">
				<div class="flex-row dtech-pad-top-10 dtech-pad-bottom-10">
					<img class="dtech-pad-right-10"
						src="x_153465_discovert.Warning16.svg"/>
					<span class="dtech-pad-right-10">
						<span class="dtech-pad-right-10">
							{{dtechWarningObject.warning.childBeforeParent_msg}}
						</span>
					</span>
					<span class="flex-column justify-end text-nowrap dtech-pad-left-10 dtech-avatar-link"
							ng-click="d.openModal($event)">
						${gs.getMessage("Show Me...")}
					</span>
				</div>
			</div>
		</div>
	</script>	
</span>
]]></xml>
    </sys_ui_macro>
</record_update>
