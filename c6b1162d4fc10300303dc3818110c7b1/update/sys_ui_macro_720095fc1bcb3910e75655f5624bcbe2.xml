<?xml version="1.0" encoding="UTF-8"?><record_update table="sys_ui_macro">
    <sys_ui_macro action="INSERT_OR_UPDATE">
        <active>true</active>
        <category>general</category>
        <description>HTML Template used in the Angular Provider Directive: dtechWarning</description>
        <media_type/>
        <name>dtechWarning.html</name>
        <scoped_name>x_153465_discovert_dtechWarning.html</scoped_name>
        <sys_class_name>sys_ui_macro</sys_class_name>
        <sys_created_by>rjoy</sys_created_by>
        <sys_created_on>2023-12-09 01:10:03</sys_created_on>
