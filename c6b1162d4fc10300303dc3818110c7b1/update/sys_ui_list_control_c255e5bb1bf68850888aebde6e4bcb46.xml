        <new_condition><![CDATA[// RAJ 2020.02.12  STRY0059160
// only allow documents to be added to the shared attachments list if the top task has shared a folder
var answer;
// RAJ 2020.02.22  STRY0059166 - this passes the value of the Shared Documents to the form.
var UseAttachmentsorDocuments = gs.getProperty("x_153465_discovert.UseAttachmentsorDocuments");
// look at the Taskser settings to see if ServiceNow Attachmetns are on
var UsesSnowAttachments = (UseAttachmentsorDocuments.startsWith("1") || UseAttachmentsorDocuments.startsWith("3"));	

if((parent.u_top_task.u_shared_attachments == true) && UsesSnowAttachments)
	answer = false;	
else
	answer = true;
]]></new_condition>
