        <xml><![CDATA[<?xml version="1.0" encoding="utf-8" ?>
<!--j:jelly trim="false" xmlns:j="jelly:core" xmlns:g="glide" xmlns:j2="null" xmlns:g2="null"-->
<j:jelly trim="false" xmlns:j="jelly:core" xmlns:g="glide" xmlns:j2="null" xmlns:g2="null">
<!--The <g:evaluate/> section exposes the server context. Phase 1-->

<div id="commonMacro"><g:macro_invoke macro="x_dtll2_contentint_CommonMacro"/></div> 
<div id="commonMacroMessage">No ServiceNow record provided.</div> 

<g:evaluate var="jvar_var_res" object="true" jelly="true">
    var result = new x_153465_discovert.taskerDocumentScripts();
    var ins = result.isInstalled();
    var resConcat = ins.code + ' - ' + ins.msg;//int
    var res = resConcat;
    res;
</g:evaluate>

<script>
    renderDiv("${jvar_var_res}", document);
    function renderDiv(res, document){
        debugger;
        var url = new URL(document.URL);
        var params = new URLSearchParams(url.search);
        var sysid = params.get('sys_id');
        if(sysid == "-1" || sysid == ""){
            var mac = document.getElementById("commonMacro");
            mac.remove();
            document.getElementById("commonMacroMessage").textContent = "No ServiceNow record provided";
        }
        else{
            if(res == '1 - Docintegrator is Activated and Installed'){
                var msg = document.getElementById("commonMacroMessage");
                msg.remove();
            }
            else{
                var mac = document.getElementById("commonMacro");
                mac.remove();
                document.getElementById("commonMacroMessage").textContent = res;
            }
        }
    }
</script>   

<!--j:if test="${jvar_var_res == '1Docintegrator is Installed'}">   
    <g:macro_invoke macro="x_dtll2_contentint_CommonMacro"/>
</j:if>
<j:if test="${jvar_var_res != '1Docintegrator is Installed'}">  
    <p>Message: ${jvar_var_res}</p>
</j:if-->

</j:jelly>]]></xml>
