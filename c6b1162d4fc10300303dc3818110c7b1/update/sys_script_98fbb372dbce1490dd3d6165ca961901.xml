        <script><![CDATA[// Copyrights belong to Discover Technologies LLC. © 2019 Discover Technologies LLC
// Script Continued Below
(function executeRule(current, previous /*null when async*/) {

	// if the task is a top task, has an exteranl tasking authority with an external ou, and the External task ID is populated, create a URL and save it.
	if(current.parent.nil() && current.tasking_authority.u_external_flag && current.tasking_authority.u_external_key + '' != '' & current.external_task_id_number + '' != ''){
		
		current.u_external_task_url = current.tasking_authority.u_external_key + current.external_task_id_number;
		
	} else if(!current.parent.nil() && !current.u_external_ou.nil() && current.u_external_ou.u_external_key + '' != '' & current.external_task_id_number + '' != ''){
		
		current.u_external_task_url = current.u_external_ou.u_external_key + current.external_task_id_number;
		
	}

})(current, previous);]]></script>
