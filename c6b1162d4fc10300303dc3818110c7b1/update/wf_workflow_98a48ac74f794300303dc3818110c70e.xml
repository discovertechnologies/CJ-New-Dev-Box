        <value>answer = generateSubTaskers();&#13;
function generateSubTaskers() {&#13;
	&#13;
	// STRY0011020 - RAJ - 2018-02-24 - rebuilt routine to support multiple route orders.&#13;
	// NOTE:  this is the same logic EXACTLY in "Discover Process Tasker Top" except that this recursively calls itself.&#13;
	workflow.scratchpad.u_Task_route_order_count +=1;&#13;
	// we query to get the list of all Task Defs in this "route order"&#13;
	// the loop below will process each Task Defs in this route order&#13;
	// it will increment the total Task Defs processed for each order&#13;
	var taskDefQ = new GlideRecord('x_153465_discovert_route_tasks');&#13;
	taskDefQ.addQuery('parent',current.source_definition);&#13;
	// if this is the fisrt pass, the route order is 0 b/c it started at -1&#13;
	// account for any task definitions that didn't set a route order and load them first&#13;
	// NOTE:  TODO - account for this in the top level task also&#13;
	if (workflow.scratchpad.u_Task_route_order_count&gt;0){&#13;
		taskDefQ.addQuery('route_order',workflow.scratchpad.u_Task_route_order_count);&#13;
	}&#13;
	// STRY0085827 - do not run task templates that were deactivated&#13;
	taskDefQ.addQuery('active', true);&#13;
	taskDefQ.query();&#13;
	&#13;
	var maxTaskOrderOffset = 0;&#13;
	var wf = new global.Workflow();&#13;
	while (taskDefQ.next()){&#13;
		var recTaskInst = new GlideRecord('x_153465_discovert_route_task_instance');&#13;
		recTaskInst.initialize();&#13;
		//  this is the relationship to the route instance&#13;
		recTaskInst.source_definition = taskDefQ.sys_id;&#13;
		recTaskInst.parent = current.sys_id;&#13;
		&#13;
		recTaskInst.u_task_requester = current.parent.originator;&#13;
		var gdt = new GlideDateTime();&#13;
		if(!current.expected_start.nil()){&#13;
			gdt.setValue(current.expected_start);&#13;
		}&#13;
		var durationAdd;&#13;
		// Set estimated Start and Estimated Duration&#13;
		if (workflow.scratchpad.u_current_duration_offset &gt; 0 )&#13;
			{&#13;
			durationAdd=workflow.scratchpad.u_current_duration_offset;&#13;
			gdt.add(durationAdd);&#13;
		}&#13;
		recTaskInst.expected_start = gdt.getValue();&#13;
		&#13;
		if(!taskDefQ.duration.nil()){&#13;
			durationAdd=taskDefQ.duration.dateNumericValue();&#13;
			// if this is the max duration for the route in the current Route Order, reset within the loop&#13;
			if(durationAdd&gt;maxTaskOrderOffset){&#13;
				maxTaskOrderOffset = durationAdd;&#13;
			}&#13;
			&#13;
			gdt.add(durationAdd);&#13;
		}&#13;
		recTaskInst.suspense_date = gdt.getValue();&#13;
		recTaskInst.due_date = gdt.getValue();&#13;
		&#13;
		recTaskInst.tasker_process_instance = current.tasker_process_instance.sys_id;&#13;
		&#13;
		recTaskInst.source_definition = taskDefQ.sys_id;&#13;
		// NOTE: TODO: set number to parent number here...&#13;
		recTaskInst.insert();&#13;
		&#13;
		var  wfId = wf.getWorkflowFromName("Discover Process Task");&#13;
		wf.startFlow(wfId, recTaskInst, 'Update');&#13;
		&#13;
		// increment the total routes processed for each route in this order&#13;
		workflow.scratchpad.u_Tasks_loaded_count +=1;&#13;
	}&#13;
	workflow.scratchpad.u_current_duration_offset = workflow.scratchpad.u_current_duration_offset + maxTaskOrderOffset;&#13;
}</value>
