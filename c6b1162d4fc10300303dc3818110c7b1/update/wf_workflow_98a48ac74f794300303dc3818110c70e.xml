        <value>answer = LogStartOfTopTaskerRuntime();&#13;
function LogStartOfTopTaskerRuntime() {&#13;
	workflow.scratchpad.u_total_Tasks = 0;&#13;
	var taskDefQ = new GlideAggregate('x_153465_discovert_route_tasks');&#13;
	taskDefQ.addQuery('parent',current.source_definition);&#13;
	// STRY0085827 - do not run task templates that were deactivated&#13;
	taskDefQ.addQuery('active', true);&#13;
	&#13;
	taskDefQ.addAggregate('COUNT');&#13;
	taskDefQ.query();&#13;
	if (taskDefQ.next()){&#13;
		workflow.scratchpad.u_total_Tasks = taskDefQ.getAggregate('COUNT');&#13;
	}&#13;
	workflow.scratchpad.u_Tasks_loaded_count = 0;&#13;
	// allow second with no order set to be processed&#13;
	// TODO, may need to apply this to the top level also&#13;
	workflow.scratchpad.u_Task_route_order_count = -1;&#13;
	workflow.scratchpad.u_current_duration_offset = 0;&#13;
	&#13;
}</value>
