<?xml version="1.0" encoding="UTF-8"?><record_update table="content_block_programmatic">
    <content_block_programmatic action="INSERT_OR_UPDATE">
        <active>true</active>
        <category>general</category>
        <condition/>
        <conditional>false</conditional>
        <frame/>
        <logged_on>false</logged_on>
        <name>Advanced Filter bkup</name>
        <programmatic_content><![CDATA[<?xml version="1.0" encoding="utf-8" ?>
<j:jelly trim="false" xmlns:j="jelly:core" xmlns:g="glide" xmlns:j2="null" xmlns:g2="null">

	<g:evaluate var="jvar_sOfficesWhereIamATaskManagers" jelly="true">
	var sOfficesWhereIamATaskManagers= new x_153465_discovert.tasking_System_Settings_Scripts().getMyOUTaskManagers();
		sOfficesWhereIamATaskManagers;
	</g:evaluate>	
	
	<g:evaluate var="jvar_TaskManagerOUsAndDescendents" jelly="true">
	var TaskManagerOUsAndDescendents= new x_153465_discovert.tasking_System_Settings_Scripts().getTaskManagerOUsAndDescendents(gs.getUserID());
		TaskManagerOUsAndDescendents;
	</g:evaluate>
	
	<!-- Tasks related to OUs where I am a Task Manager -->
<!-- 	${jvar_sOfficesWhereIamATaskManagers} -->
<!-- 	<br/> -->

<script>
	var my_dashboardMessageHandler = new DashboardMessageHandler("Advanced_Filter_1");
<!-- Filter on Task Manager OUs on load -->
	document.getElementById("dt_filter_task_manager").onload = updateFilter();
	
	function updateFilter() {
	var sOfficesWhereIamATaskManagers = "${jvar_sOfficesWhereIamATaskManagers}";
	var TaskManagerOUsAndDescendents = "${jvar_TaskManagerOUsAndDescendents}";
	var topTaskChecked = document.getElementById('dt_filter_top_tasks').checked;
	var taskManagerChecked = document.getElementById('dt_filter_task_manager').checked;
	var taskManagerDescendentsChecked = document.getElementById('dt_filter_descendents').checked;
	var filter_message = {};
	var sFilter = "";
	
	filter_message.id = "Advanced_Filter_1";
	filter_message.filter = "";
	
 	if(taskManagerChecked){
		sFilter += 'primary_officeIN' + sOfficesWhereIamATaskManagers;
	    <!-- alert(sFilter); -->
		}
	if(taskManagerDescendentsChecked){
		sFilter = sFilter=='' ? '' : sFilter + '^OR';
		sFilter += 'primary_officeIN' + TaskManagerOUsAndDescendents;
	    alert(sFilter);
		}
	if(topTaskChecked){ 
		sFilter = sFilter=='' ? '' : sFilter + '^';
		sFilter += 'parent=NULL';
		alert(sFilter);
		}
	
<!-- 	 if(taskingAuthorityChecked){ 
		sFilter = 'tasking_authorityIN' + sOfficesWhereIamAMember;
		alert(sFilter);
	 }
	 if(primaryOfficeChecked){ 
		sFilter = sFilter=='' ? '' : sFilter + '^OR';
		sFilter += 'primary_officeIN' + sOfficesWhereIamAMember;
		alert(sFilter);
	 }
	 if(primaryAssigneeChecked){ 
		sFilter = sFilter=='' ? '' : sFilter + '^OR';
		sFilter += 'primary_assigneeIN' + sOfficesWhereIamAMember;
		alert(sFilter);
	 } -->
	
	
	 filter_message.table = "x_153465_discovert_route_task_instance";
	 filter_message.filter = sFilter;
	 SNC.canvas.interactiveFilters.setDefaultValue({
		id: filter_message.id,
		filters: [filter_message]
		}, false);
	 my_dashboardMessageHandler.publishFilter(filter_message.table, filter_message.filter);
    } 		
	
</script>	
	
<div class="widget-content interactive-filter__widget-content" role="group" aria-labelledby="header-title-test">
	<div class="row interactive-filter__row">
	<span class="input-group-checkbox">
	<input class="checkbox" id="dt_filter_top_tasks" type="checkbox" value="0" name="top_task" aria-checked="true" onchange="updateFilter();">
	<label for="dt_filter_top_tasks" class="checkbox-label">Top Tasks Only
	</label>
	</input>
	</span>
	</div>
</div>
<div class="widget-content interactive-filter__widget-content" role="group" aria-labelledby="header-title-test2">
	<div class="row interactive-filter__row">
	<span class="input-group-checkbox">
	<input class="checkbox" id="dt_filter_task_manager" type="checkbox" value="0" name="task_manager" aria-checked="true" checked="checked" onclick="return false;">
	<label for="dt_filter_task_manager" class="checkbox-label">Offices I Manage
	</label>
	</input>
	</span>
	</div>
</div>
<div class="widget-content interactive-filter__widget-content" role="group" aria-labelledby="header-title-test3">
	<div class="row interactive-filter__row">
	<span class="input-group-checkbox">
	<input class="checkbox" id="dt_filter_descendents" type="checkbox" value="0" name="descendents" aria-checked="true" onchange="updateFilter();">
	<label for="dt_filter_descendents" class="checkbox-label">Include Offices I Oversee
	</label>
	</input>
	</span>
	</div> 
</div>
</j:jelly>]]></programmatic_content>
