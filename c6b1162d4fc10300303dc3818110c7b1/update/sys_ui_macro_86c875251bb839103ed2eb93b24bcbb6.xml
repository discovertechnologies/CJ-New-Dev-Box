        <sys_policy/>
        <sys_scope display_value="Tasker">c6b1162d4fc10300303dc3818110c7b1</sys_scope>
        <sys_update_name>sys_ui_macro_86c875251bb839103ed2eb93b24bcbb6</sys_update_name>
        <sys_updated_by>rjoy</sys_updated_by>
        <sys_updated_on>2023-12-15 02:20:23</sys_updated_on>
        <xml><![CDATA[<span role="button"
	ng-class="{'flex-column':dtechIsDark!=true,
				'justify-center':dtechIsDark!=true,
				'dtech-btn': dtechIsDark!=true,
				'dtech-disabled': data.submitting,
				'dtech-enabled': !data.submitting}"
	ng-click="d.showActions($event);" 
	ng-mouseleave="d.parentMouseLeave();"

	uib-popover-template="'template-actions.html'"
	popover-trigger="none"
	popover-is-open="dtechToolTipOpen"
	popover-placement="{{dtechPopoverPlacement}}"
	popover-animation="true"
	
	popover-append-to-body="dtechIsModal==false"
	>
<!-- popover-class="dtech-popover-container-box-shadow" -->	
	<!-- popover-popup-delay="{{d.popoverDelay}}" no delay on actions, it is a click event-->
		<span class="pointer" 
			type="button"
			ng-class="{'dtech-dark-btn':dtechIsDark==true, 
					'dtech-pad-left-5': dtechIsDark!=true,
					'dtech-border-none': dtechIsDark!=true}"
				>
			<img ng-disabled="data.submitting"
					src="{{d.getImage()}}"/>
		</span>

	<script type="text/ng-template" id="template-actions.html">
		<span ng-mouseenter="d.enterTooltip();"
			 ng-mouseleave="d.leaveTooltip();"
			 ng-init="d.initTooltip();"
			 class="flex-column dtech-action-menu-container">
				<span ng-show="!dtechActionsObject.ui_actions">
					<span class="dtech-action-menu-spinner-container">
						<fa name="spinner" spin="true"></fa>
					</span>
				</span>
				<span ng-show="dtechActionsObject.ui_actions">
					<span ng-repeat="action in dtechActionsObject.ui_actions | orderBy : 'order' track by action.sys_id">
						<span ng-if="action.name!='separator'"
							 class="dtech-action-dropdown"
							 ng-click="d.executeAction($event, action);d.leaveTooltip();">
								<img class="dtech-enabled dtech-pad-right-10"
										src="{{action.image}}" title="{{action.hint}}"
										alt="{{action.hint}}" />
										
								<span>{{action.name}}</span>
						</span>
						<div ng-if="action.name=='separator'"
							 class="dtech-action-menu-item-divider"/>
					</span>
				</span>

		</span>
	</script>
</span>]]></xml>
    </sys_ui_macro>
</record_update>
