        <xml><![CDATA[<span role="button"
	  class="flex-column justify-center"> 

	<span ng-click="d.showActions($event);" 
		  ng-mouseleave="d.parentMouseLeave();">

		<span uib-popover-template="'template-Actions.html'"
			  popover-trigger="none"
			  popover-is-open="dtechActionsToolTipOpen"
			  popover-placement="auto"
			  popover-animation="true"
			  popover-class="dtech-popover-container-duration" 
			  popover-append-to-body="dtechIsModal==false"
			  popover-popup-delay="{{d.popoverDelay}}">


			<div class="dtech-border-none dtech-pad-left-5 pointer dtech-btn" 
				 ng-class="{'dtech-disabled': data.submitting,
						   'dtech-enabled': !data.submitting}"
				 type="button">
				<img ng-disabled="data.submitting"
					 src="EllipsesMenu32.svg"/>
			</div>
		</span>
	</span>
	<script type="text/ng-template" id="template-Actions.html">
		<div ng-mouseenter="d.enterTooltip();"
			 ng-mouseleave="d.leaveTooltip();"
			 ng-init="d.initTooltip();"
			 class="flex-column">
			<div >
				<div ng-if="d.isSpinnerShown">
					<div class="dtech-popover-list-spinner-content">
						<fa name="spinner" spin="true"></fa>
					</div>
				</div>
				<div ng-if="!d.isSpinnerShown">
					<div class="" 
						 ng-repeat="action in dtechActionsObject.ui_actions | orderBy : 'order' track by action.sys_id">
						<div ng-if="action.name!='separator'"
							 class="row"
							 ng-click="d.executeAction($event, action);d.leaveTooltip();">
							<div class="col-sm-12 ">
								<div class="">
									<a >
										<img class="dtech-enabled dtech-pad-all-10"
											 src="{{action.image}}" title="{{action.hint}}"
											 alt="{{action.hint}}" />
										{{action.name}}
									</a>
								</div>
							</div>
						</div>
						<div ng-if="action.name=='separator'"
							 class="row col-sm-12 dtech-menu-item-divider"/>
					</div>
				</div>

			</div>
		</div>
	</script>
</span>]]></xml>
    </sys_ui_macro>
</record_update>
