        <sys_updated_on>2022-07-16 20:10:22</sys_updated_on>
        <xml><![CDATA[<div id="ngProPopOverList">
	<div ng-if="popoverListOptions.isSimplePopover" class="dtech-popover-list-outer-container-md dtech-arrow-up">
		<div class="dtech-avatar-text-standard-16 text-center">
			{{dtechParamObject.title}}
		</div>
		<div ng-if="dtechParamObject.footerLink" class="dtech-avatar-link text-center" ng-click="openUrlInNewTab()">
			{{dtechParamObject.footerLink}}
		</div>
	</div>
	<div ng-if="!popoverListOptions.isSimplePopover" class="dtech-popover-list-outer-container-lg dtech-arrow-up">
		<header id="header" class="text-left m-b-sm">
			<span class="text-uppercase dtech-avatar-text-standard-14">{{dtechParamObject.title}}</span>
		</header>
		<main class="dtech-popover-list-main-container" >
			<div ng-if="popoverListOptions.isSpinnerShown" class="dtech-popover-list-spinner-content">
				<fa name="spinner" spin="true"></fa>
			</div>
			<div ng-if="!popoverListOptions.isSpinnerShown">
				<ul class="list-unstyled">
					<li class="dtech-margin-bottom-inherit" ng-repeat="person in dtechParamObject.persons | limitTo: popoverListOptions.maxRowsToDisplay track by person.sys_id">
						<div class="avatar-container dtech-avatar-round-32rem">
							<div class="avatar soloAvatar dtech-avatar-bg-color-transparent">
								<div class="sub-avatar dtech-avatar-bg-color" style="{{person.photo}}"></div>
							</div>
						</div>
						<span class="m-l-xs dtech-avatar-link" ng-click="openUserProfileModal(person.sys_id)">{{person.name}}</span>
					</li>
				</ul>
			</div>
			<div ng-if="dtechParamObject.persons.length == 0" 
				 class="dtech-popover-list-footer-content">
				<span class="m-l-xs ">{{dtechParamObject.emptyState}}</span>
			</div>

		</main>
		<footer ng-if="dtechParamObject.footerLink">
			<div ng-if="dtechParamObject.persons.length > popoverListOptions.maxRowsToDisplay" 
				 class="dtech-popover-list-footer-content dtech-avatar-link" ng-click="openSomeModal(dtechParamObject.modalType)">{{dtechParamObject.footerLink}}
			</div>
		</footer>
	</div>
</div>]]></xml>
    </sys_ui_macro>
</record_update>
