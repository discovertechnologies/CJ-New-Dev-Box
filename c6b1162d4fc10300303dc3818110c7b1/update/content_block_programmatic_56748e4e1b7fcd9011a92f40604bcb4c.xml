<?xml version="1.0" encoding="UTF-8"?><record_update table="content_block_programmatic">
    <content_block_programmatic action="INSERT_OR_UPDATE">
        <active>true</active>
        <category>general</category>
        <condition/>
        <conditional>false</conditional>
        <frame/>
        <logged_on>false</logged_on>
        <name>Advanced Filter b</name>
        <programmatic_content><![CDATA[<?xml version="1.0" encoding="utf-8" ?>
<j:jelly trim="false" xmlns:j="jelly:core" xmlns:g="glide" xmlns:j2="null" xmlns:g2="null">

	<g:evaluate var="jvar_sOfficesWhereIamATaskManagers" jelly="true">
	var sOfficesWhereIamATaskManagers= new x_153465_discovert.tasking_System_Settings_Scripts().getMyOUTaskManagers();
		sOfficesWhereIamATaskManagers;
	</g:evaluate>	
	
	<g:evaluate var="jvar_TaskManagerOUsAndSubOffices" jelly="true">
	var TaskManagerOUsAndSubOffices= new x_153465_discovert.tasking_System_Settings_Scripts().getTaskManagerOUsAndDescendents(gs.getUserID(),1);
		TaskManagerOUsAndSubOffices;
	</g:evaluate>
	
	<g:evaluate var="jvar_TaskManagerOUsAndDescendants" jelly="true">
	var TaskManagerOUsAndDescendants= new x_153465_discovert.tasking_System_Settings_Scripts().getTaskManagerOUsAndDescendents(gs.getUserID());
		TaskManagerOUsAndDescendants;
	</g:evaluate>
	
<script>
	var my_dashboardMessageHandler = new DashboardMessageHandler("Advanced_Filter_2");
	
	function updateFilter() {
	var sOfficesWhereIamATaskManagers = "${jvar_sOfficesWhereIamATaskManagers}";
	var TaskManagerOUsAndSubOffices = "${jvar_TaskManagerOUsAndSubOffices}";
	var TaskManagerOUsAndDescendants = "${jvar_TaskManagerOUsAndDescendants}";
	var topTaskChecked = document.getElementById('dt_filter_top_tasks').checked;
	var taskManagerSubOfficesChecked = document.getElementById('dt_filter_task_manager_subs').checked;
	var taskManagerDescendantsChecked = document.getElementById('dt_filter_task_manager_desc').checked;
	var taskManagerChecked = document.getElementById('dt_filter_manager').checked;
	var filter_message = {};
	var sFilter = "";
	filter_message.id = "Advanced_Filter_1";
	filter_message.filter = "";
	
	if(taskManagerDescendantsChecked){
		sFilter += 'tasking_authorityIN' + TaskManagerOUsAndDescendants + 
				   '^OR' + 'primary_officeIN' + TaskManagerOUsAndDescendants + 
				   '^OR' + 'primary_assigneeIN' + TaskManagerOUsAndDescendants;
	   	}
	if(taskManagerSubOfficesChecked){
		sFilter += 'tasking_authorityIN' + TaskManagerOUsAndSubOffices + 
				   '^OR' + 'primary_officeIN' + TaskManagerOUsAndSubOffices + 
				   '^OR' + 'primary_assigneeIN' + TaskManagerOUsAndSubOffices;
	   	}	
	if(taskManagerChecked){
		sFilter = sFilter=='' ? '' : sFilter + '^OR';
		sFilter = 'tasking_authorityIN' + sOfficesWhereIamATaskManagers + 
			   '^OR' + 'primary_officeIN' + sOfficesWhereIamATaskManagers + 
			   '^OR' + 'primary_assigneeIN' + sOfficesWhereIamATaskManagers;
	   	}
	if(topTaskChecked){ 
		sFilter = sFilter=='' ? '' : sFilter + '^';
		sFilter += 'parent=NULL';
		}
		
	 filter_message.table = "x_153465_discovert_route_task_instance";
	 filter_message.filter = sFilter;
	 SNC.canvas.interactiveFilters.setDefaultValue({
		id: filter_message.id,
		filters: [filter_message]
		}, false);
	 my_dashboardMessageHandler.publishFilter(filter_message.table, filter_message.filter);
    } 		
</script>	
	
<div class="widget-content interactive-filter__widget-content" role="group" aria-labelledby="header-top-tasks">
	<div class="row interactive-filter__row">
	<span class="input-group-checkbox">
	<input class="checkbox" id="dt_filter_top_tasks" type="checkbox" value="0" name="top_task" aria-checked="true" onchange="updateFilter();">
	<label for="dt_filter_top_tasks" class="checkbox-label">Limit to Top Tasks
	</label></input></span></div>
</div>
<div class="widget-content interactive-filter__widget-content" role="group" aria-labelledby="header-taskmanager-descendents">
	<div class="row interactive-filter__row">
	<span class="input-group-checkbox">
	<input class="checkbox" id="dt_filter_manager" type="checkbox" value="0" name="task_manager" aria-checked="true" onchange="updateFilter();">
	<label for="dt_filter_manager" class="checkbox-label">Offices I Manage
	</label></input></span></div> 
</div>	
<div class="widget-content interactive-filter__widget-content" role="group" aria-labelledby="header-taskmanager-suboffices">
	<div class="row interactive-filter__row">
	<span class="input-group-checkbox">
	<input class="checkbox" id="dt_filter_task_manager_subs" type="checkbox" value="0" name="task_manager_subs" aria-checked="true" onchange="updateFilter();">
	<label for="dt_filter_task_manager_subs" class="checkbox-label">Offices I Manage and Immediate Sub-Offices
	</label></input></span></div>
</div>
<div class="widget-content interactive-filter__widget-content" role="group" aria-labelledby="header-taskmanager-suboffices">
	<div class="row interactive-filter__row">
	<span class="input-group-checkbox">
	<input class="checkbox" id="dt_filter_task_manager_desc" type="checkbox" value="0" name="task_manager_desc" aria-checked="true" onchange="updateFilter();" onclick="return false;" onkeydown="return false;">
	<label for="dt_filter_task_manager_desc" class="checkbox-label">Offices I Manage and All Descendants
	</label></input></span></div>
</div>	
<div class="widget-content interactive-filter__widget-content" role="radiogroup" aria-label="Closed On-Time">
	<div class="row interactive-filter__row">
	<span class="input-group-radio" role="radio">
	<input class="radio" id="radio_9813192d1b19cd1011a92f40604bcba9_default" type="radio" aria-checked="false" tabindex="-1" value="All" name="radio_9813192d1b19cd1011a92f40604bcba9" checked="checked">
	<label for="radio_9813192d1b19cd1011a92f40604bcba9_default" class="radio-label">All
	</label></input></span></div>
</div>
<div class="widget-content interactive-filter__widget-content" role="radiogroup" aria-label="true">	
	<div class="row interactive-filter__row">
	<span class="input-group-radio" role="radio">
	<input class="radio" id="radio_9813192d1b19cd1011a92f40604bcba9_true" aria-checked="true" tabindex="0" type="radio" value="true" name="radio_9813192d1b19cd1011a92f40604bcba9">
	<label for="radio_9813192d1b19cd1011a92f40604bcba9_true" class="radio-label">true
	</label></input></span></div>
</div>
</j:jelly>]]></programmatic_content>
