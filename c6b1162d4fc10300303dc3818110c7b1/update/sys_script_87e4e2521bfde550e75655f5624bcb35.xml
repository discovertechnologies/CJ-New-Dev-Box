        <script><![CDATA[(function executeRule(current, previous /*null when async*/) {
	var value = "";
	switch(current.getValue("u_action_taken")){
		case "sent_to_review":
			value="response";
			break;
		case "sent_to_rework":
			value="rework_comments";
			break;
		case "completed":
			switch(current.getValue("u_role")){
				case "reviewer":
					value="comments_dt";
					break;
				default:
					value = "response";
					break;
			}
			break;
		case "reopened":
			value="reopen_comments";
			break;
		default:
			value = "comments_dt";
			break;
	}
	current.u_comment_type=value;
})(current, previous);]]></script>
