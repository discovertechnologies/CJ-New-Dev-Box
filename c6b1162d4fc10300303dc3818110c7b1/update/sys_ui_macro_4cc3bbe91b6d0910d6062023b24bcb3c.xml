        <xml><![CDATA[<div class="dtech-user-profile"
	 ng-mouseenter="d.profileMouseEnter()" 
	 ng-mouseleave="d.profileMouseLeave()" >
	<div id="ngProPopOverAvatar" class="dtech-popover-container-avatar dtech-arrow-up">
		<div class="row">
			<div class="col-md-12 text-center">
				<div class="row">
					<div class="avatar-container dtech-avatar-round-64rem">
						<div class="avatar soloAvatar dtech-avatar-bg-color-transparent">
							<div  class="sub-avatar dtech-avatar-bg-color" style="{{dtechUserProfile.photoBackground}}">
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
		<div class="row">
			<div class="col-md-12 text-center dtech-avatar-text-standard-16 dtech-margin-top-5px">{{dtechUserProfile.name}}</div>
		</div>
		<div class="row">
			<div class="col-md-12 text-center">
				<span class="dtech-avatar-link" ng-click="d.openUserProfileModal()">${gs.getMessage("Tasker - Open Profile Page")}</span>
			</div>
		</div>
		<div class="row">
			<div class="col-md-12 text-center dtech-margin-top-5px">
				<button ng-if="d.connectEnabled()" ng-click="d.openConnectConversation()" type="button"
						class="btn btn-primary send-message"><span class="glyphicon glyphicon-comment pad-right"></span>${gs.getMessage("Tasker - Open Contact Page")}</button>
			</div>
		</div>
		<div class="row">
			<div ng-if="dtechUserProfile.email" class="col-md-12 text-left dtech-pad-top-10">
				<img src="Mail16.svg" title="${gs.getMessage('Send Mail')}"
					 alt="${gs.getMessage('Send Mail')}" class="dtech-pad-left-10 dtech-pad-right-10"/>
				<span class="dtech-avatar-text-standard-16" ng-click="d.sendMailTo()">{{dtechUserProfile.email}}</span>
			</div>
		</div>
		<div class="row">
			<div ng-if="dtechUserProfile.businessPhone" class="col-md-12 text-left dtech-margin-top-5px">
				<img src="BusinessPhone16.svg" title=""
					 alt="" class="dtech-pad-left-10 dtech-pad-right-10"/>
				<span class="dtech-avatar-text-standard-16">{{dtechUserProfile.businessPhone}}</span>
			</div>
		</div>
		<div class="row">
			<div ng-if="dtechUserProfile.mobilePhone" class="col-md-12 text-left dtech-margin-top-5px">
				<img src="Phone16.svg" title=""
					 alt="" class="dtech-pad-left-10 dtech-pad-right-10"/>
				<span class="dtech-avatar-text-standard-16">{{dtechUserProfile.mobilePhone}}</span>
			</div>
		</div>
		<div class="dtech-footer-row-sticky">
			<div class="col-md-6 dtech-pad-left-0 text-left dtech-avatar-text-standard-14 dtech-opacity-50">{{dtechUserProfile.location}}</div>
			<div class="col-md-6 dtech-pad-right-0 text-right dtech-avatar-text-standard-14 dtech-opacity-50">{{dtechUserProfile.time_zone}}</div>
		</div>
	</div>
</div>]]></xml>
    </sys_ui_macro>
