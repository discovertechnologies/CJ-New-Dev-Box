        <xml><![CDATA[<div>
	<div class="dtech-popover-arrow-up"></div>
	<div id="ngProPopOverAvatar" class="dtech-popover-container-avatar">
		<div class="row">
			<div class="col-md-12 text-center">
				<div class="row">
					<div class="avatar-container dtech-avatar-round-64rem">
						<div class="avatar soloAvatar dtech-avatar-bg-color-transparent">
							<div  class="sub-avatar dtech-avatar-bg-color" style="{{dtechParamObject.photo}}">
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
		<div class="row">
			<div class="col-md-12 text-center dtech-avatar-text-standard-16 dtech-margin-top-5px">{{dtechParamObject.name}}</div>
		</div>
		<div class="row">
			<div class="col-md-12 text-center">
				<span class="dtech-avatar-link" ng-click="openUserProfileTab()">{{dtechParamObject.messages.row3Message}}</span>
			</div>
		</div>
		<div class="row">
			<div class="col-md-12 text-center dtech-margin-top-5px">
				<button ng-if="connectEnabled()" ng-click="openConnectConversation()" type="button"
						class="btn btn-primary send-message"><span class="glyphicon glyphicon-comment pad-right"></span>{{dtechParamObject.messages.buttonText}}</button>
			</div>
		</div>
		<div class="row">
			<div ng-if="dtechParamObject.email" class="col-md-12 text-left dtech-pad-top-10">
				<img src="{{dtechParamObject.icons.Mail16.src}}" title="{{dtechParamObject.icons.Mail16.title}}"
					 alt="{{dtechParamObject.icons.Mail16.alt}}" class="dtech-pad-left-10 dtech-pad-right-10"/>
				<span class="dtech-avatar-text-standard-16" ng-click="sendMailTo()">{{dtechParamObject.email}}</span>

			</div>
		</div>
		<div class="row">
			<div ng-if="dtechParamObject.businessPhone" class="col-md-12 text-left dtech-margin-top-5px">
				<img src="{{dtechParamObject.icons.BusinessPhone16.src}}" title="{{dtechParamObject.icons.BusinessPhone16.title}}"
					 alt="{{dtechParamObject.icons.BusinessPhone16.alt}}" class="dtech-pad-left-10 dtech-pad-right-10"/>
				<span class="dtech-avatar-text-standard-16">{{dtechParamObject.businessPhone}}</span>
			</div>
		</div>
		<div class="row">
			<div ng-if="dtechParamObject.mobilePhone" class="col-md-12 text-left dtech-margin-top-5px">
				<img src="{{dtechParamObject.icons.Phone16.src}}" title="{{dtechParamObject.icons.Phone16.title}}"
					 alt="{{dtechParamObject.icons.Phone16.alt}}" class="dtech-pad-left-10 dtech-pad-right-10"/>
				<span class="dtech-avatar-text-standard-16">{{dtechParamObject.mobilePhone}}</span>
			</div>
		</div>
		<div class="dtech-footer-row-sticky">
			<div class="col-md-6 dtech-pad-left-0 text-left dtech-avatar-text-standard-14 dtech-opacity-50">{{dtechParamObject.location}}</div>
			<div class="col-md-6 dtech-pad-right-0 text-right dtech-avatar-text-standard-14 dtech-opacity-50">{{dtechParamObject.time_zone}}</div>
		</div>
	</div>
</div>]]></xml>
    </sys_ui_macro>
