        <value>answer = LogStartOfSaveTasksToProcess();&#13;
function LogStartOfSaveTasksToProcess() {&#13;
	&#13;
	workflow.scratchpad.u_total_Tasks = 0;&#13;
	&#13;
	var taskInstQ = new GlideAggregate('x_153465_discovert_route_task_instance');&#13;
	taskInstQ.addQuery('parent',current.original_tasker_inst);&#13;
	taskInstQ.addAggregate('COUNT');&#13;
	taskInstQ.query();&#13;
	if (taskInstQ.next()){&#13;
		workflow.scratchpad.u_total_Tasks = taskInstQ.getAggregate('COUNT');&#13;
	}&#13;
	workflow.scratchpad.u_Tasks_loaded_count = 0;&#13;
	// allow second with no order set to be processed&#13;
	// TODO, may need to apply this to the top level also&#13;
	workflow.scratchpad.u_Task_route_order_count = -1;&#13;
	workflow.scratchpad.u_current_duration_offset = 0;&#13;
	&#13;
}</value>
