<?xml version="1.0" encoding="UTF-8"?><record_update table="sys_ui_macro">
    <sys_ui_macro action="INSERT_OR_UPDATE">
        <active>true</active>
        <category>general</category>
        <description>HTML Template used in the Angular Provider Directive State&#13;
This directive allows us to put the same style on the State anywhere we want to use it.  &#13;
In Task, it will show the the current state as a pill and the list of states for the type on hover.&#13;
&#13;
</description>
        <media_type/>
        <name>dtechState.html</name>
        <scoped_name>x_153465_discovert_dtechState.html</scoped_name>
        <sys_class_name>sys_ui_macro</sys_class_name>
        <sys_created_by>rjoy</sys_created_by>
        <sys_created_on>2024-01-20 21:55:41</sys_created_on>
        <sys_id>cfeff16e1bb73510e75655f5624bcb55</sys_id>
        <sys_mod_count>27</sys_mod_count>
        <sys_name>dtechState.html</sys_name>
        <sys_package display_value="Tasker" source="x_153465_discovert">c6b1162d4fc10300303dc3818110c7b1</sys_package>
        <sys_policy/>
        <sys_scope display_value="Tasker">c6b1162d4fc10300303dc3818110c7b1</sys_scope>
        <sys_update_name>sys_ui_macro_cfeff16e1bb73510e75655f5624bcb55</sys_update_name>
        <sys_updated_by>rjoy</sys_updated_by>
        <sys_updated_on>2024-02-22 15:39:12</sys_updated_on>
        <xml><![CDATA[<span role="button"
	 ng-click="d.openModal($event);d.leaveTooltip();"> 

	<span ng-mouseenter="d.showState();" 
		 ng-mouseleave="d.parentMouseLeave();">

		<span uib-popover-template="'task-popover-state.html'"
			 popover-trigger="none"
			 popover-is-open="dtechToolTipOpen"
			 popover-placement="{{dtechPopoverPlacement}}"
			 popover-animation="true"
			 popover-class="dtech-popover-container-box-shadow dtech-pad-all-10" 
			 popover-append-to-body="dtechIsModal==false"
			 popover-popup-delay="{{d.popoverDelay}}">
			<span ng-if="dtechShowLabel==true"
				  class="flex-row text-nowrap text-uppercase">
				  {{dtechStateObject.state.label}}
			</span>	
			<span class="text-nowrap"
				ng-class="{'flex-row':dtechField, 
								'dtech-dark-btn':dtechIsDark==true, 
								'dtech-btn':dtechIsDark!=true,
								'dtech-border-none':dtechIsDark!=true,
								'dtech-margin-negative-5px': dtechInDataTable==true}">
				<div ng-if="dtechShowAllStates==true" 
					ng-repeat="key in dtechStateObject.flow">
					<div ng-if="dtechStateObject.state.display_value != key.name" class="dtech-circle {{key.colour}}"/>
					<div ng-if="dtechStateObject.state.display_value == key.name" class="dtech-selected-circle {{key.colour}} text-nowrap">
						{{dtechStateObject.state.display_value}}
					</div>
				</div>
				<div ng-if="dtechShowAllStates!=true"
					class="badge {{dtechStateObject.state.display_value}} text-nowrap">
					{{dtechStateObject[dtechField].display_value}}
				</div>
			</span>
		</span>
	</span>
	<script type="text/ng-template" id="task-popover-state.html">
		<div ng-mouseenter="d.enterTooltip();"
			 ng-mouseleave="d.leaveTooltip();"
			 ng-init="d.initTooltip();"
			 class="flex-column dtech-action-menu-container">
			<div class="flex-row align-items-center dtech-action-dropdown" 
				ng-class="{'dtech-item-selected-row-background':dtechStateObject.state.display_value == key.name}"
				ng-repeat="key in dtechStateObject.flow">
				<div ng-if="dtechStateObject.state.display_value == key.name"
					class="flex-column">
					<div class="dtech-item-selected-left-indicator align-items-stretch"></div>
				</div>
				<div class="dtech-circle {{key.colour}}"/>
				<div class="dtech-legend-text">{{key.name}}</div>
			</div>
		</div>
	</script>
</span>
]]></xml>
    </sys_ui_macro>
</record_update>
