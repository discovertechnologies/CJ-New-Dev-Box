<?xml version="1.0" encoding="UTF-8"?><record_update table="sys_ui_macro">
    <sys_ui_macro action="INSERT_OR_UPDATE">
        <active>true</active>
        <category>general</category>
        <description>HTML Template used in the Angular Provider Directive: dtechDuration&#13;
2.8.5 | 2023-08-14 | raj | STRY0136615 - STRETCH-PLACEHOLDER- Header UI Control (updates to add lable and change the style for label and text)&#13;
2.8.5 | 2023-07-11 | raj | STRY0141856 - Stretch- PLACEHOLDER- Office Control&#13;
Updated to move variables into the duration object to streamline the services and &#13;
This had the added benefit of allowing the same service to be called from server and client.&#13;
Updated to change div to span on the main control so it would work in Tab Form with Tabs as well as the data table&#13;
2.8.5 | 2023-05-11 | mmcc | STRY0139742 - Increase delaying when hover directives open&#13;
Updated popover-popup-delay to use a var - "{{d.popoverDelay}}"&#13;
Added ng-init="d.initTooltip();" to first &lt;div&gt; of template-duration.html</description>
        <media_type/>
        <name>dtechDuration.html</name>
        <scoped_name>x_153465_discovert_dtechDuration.html</scoped_name>
        <sys_class_name>sys_ui_macro</sys_class_name>
        <sys_created_by>rjoy</sys_created_by>
        <sys_created_on>2023-04-07 13:17:00</sys_created_on>
        <sys_id>345fb8791b0aa110e75655f5624bcb20</sys_id>
        <sys_mod_count>73</sys_mod_count>
        <sys_name>dtechDuration.html</sys_name>
        <sys_package display_value="Tasker" source="x_153465_discovert">c6b1162d4fc10300303dc3818110c7b1</sys_package>
        <sys_policy/>
        <sys_scope display_value="Tasker">c6b1162d4fc10300303dc3818110c7b1</sys_scope>
        <sys_update_name>sys_ui_macro_345fb8791b0aa110e75655f5624bcb20</sys_update_name>
        <sys_updated_by>rjoy</sys_updated_by>
        <sys_updated_on>2023-08-18 23:42:16</sys_updated_on>
        <xml><![CDATA[<span role="button"
	 ng-click="d.openModal($event);d.leaveTooltip();"> 

	<span ng-mouseenter="d.showDuration($event);" 
		 ng-mouseleave="d.parentMouseLeave();">

		<span uib-popover-template="'template-duration.html'"
			 popover-trigger="none"
			 popover-is-open="dtechDurationToolTipOpen"
			 popover-placement="auto"
			 popover-animation="true"
			 popover-class="dtech-popover-container-duration" 
			 popover-append-to-body="dtechIsModal==false"
			 popover-popup-delay="{{d.popoverDelay}}">
			<span ng-if="dtechShowLabel==true"
				  class="flex-row text-nowrap text-uppercase">
				{{dtechDurationObject.suspense_date.label}}
			</span>
			<span ng-class="{'flex-row':dtechHideDate!=true}">
				<img ng-if="dtechDurationObject.status.display_value=='Critical'" 
					 ng-class="{'dtech-pad-right-10':dtechHideDate!=true, 'dtech-pad-all-10':dtechHideDate==true}"
					 src="x_153465_discovert.Error16.svg"/>
				<img ng-if="dtechDurationObject.status.display_value=='Warning'" 
					 ng-class="{'dtech-pad-right-10':dtechHideDate!=true, 'dtech-pad-all-10':dtechHideDate==true}"
					 src="x_153465_discovert.Warning16.svg"/>
				<img ng-if="!(dtechDurationObject.status.display_value == 'Warning' || dtechDurationObject.status.display_value == 'Critical')" 
					 ng-class="{'dtech-pad-right-10':dtechHideDate!=true, 'dtech-pad-all-10':dtechHideDate==true}"
					 src="Schedule16.svg"/>
				<span ng-if="dtechHideDate!=true">
					<span class="text-nowrap" ng-if="dtechShowLongDates!=true">
						<a class="dtech-avatar-link">{{dtechDurationObject.suspense_date.display_value}}</a>
					</span>
					<span class="text-nowrap" ng-if="dtechShowLongDates==true">
						<a class="dtech-avatar-link">{{dtechDurationObject.suspense_date.display_value.substring(0,10)| date : 'MMMM d, y'}}</a>
					</span>
				</span>
			</span>
		</span>
	</span>
	<script type="text/ng-template" id="template-duration.html">
		<div ng-mouseenter="d.enterTooltip();"
			 ng-mouseleave="d.leaveTooltip();"
			 ng-init="d.initTooltip();"
			 class="flex-column">
<!-- TODO discuss with Mark McCune if we should make this universal or create a different class for Duration -->
			<div >
				<div ng-if="dtechDurationObject.status_reason.reason" class="panel panel-default">
					<div class="panel-heading">
						<div class="flex-row">
							<img ng-if="dtechDurationObject.status.display_value=='Critical'" 
								 ng-class="{'dtech-pad-right-10':dtechDurationObject.status.display_value=='Critical'}"
								 src="x_153465_discovert.Error16.svg"/>
							<img ng-if="dtechDurationObject.status.display_value=='Warning'" 
								 ng-class="{'dtech-pad-right-10':dtechDurationObject.status.display_value=='Warning'}"
								 src="x_153465_discovert.Warning16.svg"/>
							<img ng-if="!(dtechDurationObject.status.display_value == 'Warning' || dtechDurationObject.status.display_value == 'Critical')" 
								 ng-class="{'dtech-pad-right-10': !(dtechDurationObject.status.display_value == 'Warning' || dtechDurationObject.status.display_value == 'Critical')}"
								 src="Schedule16.svg"/>
							<h3 class="panel-title">{{dtechDurationObject.status_reason.reason}}</h3>
						</div>
					</div>
				</div>
				<div ng-if="d.isSpinnerShown">
					<div class="dtech-popover-list-spinner-content">
						<fa name="spinner" spin="true"></fa>
					</div>
				</div>
				<div class="dtech-template-container-270 flex-column"
					 ng-if="!d.isSpinnerShown">
					<div ng-if="dtechDurationObject.outbound.value==true"
						 class="row dtech-w-100p">
						<div class="col-md-6 dtech-sonic-silver-text-color">
							<p>{{dtechDurationObject.outbound.label}}</p>
						</div>
						<div class="col-md-6 dtech-sonic-silver-text-color">
							<p>{{dtechDurationObject.u_external_due_date.label}}</p>
						</div>						
					</div>
					<div ng-if="dtechDurationObject.outbound.value==true"
						 class="row dtech-w-100p">
						<div class="col-md-6 dtech-modal-widget-text-black-bold">
							<span>
								<span ng-class="{'dtech-table-cell-boolean-true': dtechDurationObject.outbound.display_value=='true',
												'dtech-table-cell-boolean-false': dtechDurationObject.outbound.display_value.value=='false'}">
								</span>
								<span ng-bind-html="dtechDurationObject.outbound.display_value"/>
							</span>							
						</div>
						<div class="col-md-6 dtech-modal-widget-text-black-bold">
							<p>{{dtechDurationObject.u_external_due_date.display_value}}</p>
						</div>
					</div>
					<div class="row dtech-w-100p">
						<div class="col-md-6 dtech-sonic-silver-text-color">
							<p>{{dtechDurationObject.warning_hours.label}}</p>
						</div>
						<div class="col-md-6 dtech-sonic-silver-text-color">
							<p>{{dtechDurationObject.task_order.label}}</p>
						</div>
					</div>
					<div class="row dtech-w-100p">
						<div class="col-md-6 dtech-modal-widget-text-black-bold">
							<p>{{dtechDurationObject.warning_hours.display_value}}</p>
						</div>
						<div class="col-md-6 dtech-modal-widget-text-black-bold">
							<p>{{dtechDurationObject.task_order.display_value}}</p>
						</div>
					</div>
					<div class="row dtech-w-100p">						
						<div class="col-md-6 dtech-sonic-silver-text-color">
							<p>{{dtechDurationObject.expected_start.label}}</p>
						</div>
						<div class="col-md-6 dtech-sonic-silver-text-color">
							<p>{{dtechDurationObject.u_wait_for_subtasks_to_finish.label}}</p>
						</div>
					</div>
					<div class="row dtech-w-100p">						
						<div class="col-md-6 dtech-modal-widget-text-black-bold">
							<p>{{dtechDurationObject.expected_start.display_value}}</p>
						</div>
						<div class="col-md-6 dtech-modal-widget-text-black-bold">
							<span>
								<span ng-class="{'dtech-table-cell-boolean-true': dtechDurationObject.u_wait_for_subtasks_to_finish.display_value=='true',
												'dtech-table-cell-boolean-false': dtechDurationObject.u_wait_for_subtasks_to_finish.display_value=='false'}">
								</span>
								<span ng-bind-html="dtechDurationObject.u_wait_for_subtasks_to_finish.display_value"/>
							</span>							
						</div>
					</div>
					<div ng-if="dtechDurationObject.calendar_duration.display_value"
						 class="row dtech-w-100p">
						<div class="col-md-6 dtech-sonic-silver-text-color">
							<p>{{dtechDurationObject.calendar_duration.label}}</p>
						</div>						
						<div class="col-md-6 dtech-sonic-silver-text-color">
							<p></p>
						</div>
					</div>
					<div ng-if="dtechDurationObject.calendar_duration.display_value"
						 class="row dtech-w-100p">
						<div class="col-md-6 dtech-modal-widget-text-black-bold">
							<p>{{dtechDurationObject.calendar_duration.display_value}}</p>
						</div>
						<div class="col-md-6  dtech-modal-widget-text-black-bold">
							<p></p>
						</div>						
					</div>
					<div ng-if="dtechDurationObject.work_start.label"
						 class="row dtech-w-100p">
						<div class="col-md-6 dtech-sonic-silver-text-color">
							<p>{{dtechDurationObject.work_start.label}}</p>
						</div>
						<div class="col-md-6 dtech-sonic-silver-text-color">
							<p>{{dtechDurationObject.work_end.label}}</p>
						</div>
					</div>
					<div ng-if="dtechDurationObject.work_start.label"
						 class="row dtech-w-100p">
						<div class="col-md-6 dtech-modal-widget-text-black-bold">
							<p>{{dtechDurationObject.work_end.display_value}}</p>
						</div>
						<div class="col-md-6 dtech-modal-widget-text-black-bold">
							<p>{{dtechDurationObject.work_start.display_value}}</p>
						</div>
					</div>
				</div>
			</div>
			<div class="dtech-flex-shrink-0">
				<div class="dtech-pad-top-10">
					<div class="dtech-avatar-link dtech-display-block text-center" ng-click="d.openModal($event)">
						${gs.getMessage("Tasker - Open Duration")}
					</div>
				</div>
			</div>
		</div>
	</script>
</span>
]]></xml>
    </sys_ui_macro>
</record_update>
