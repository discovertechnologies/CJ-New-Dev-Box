<?xml version="1.0" encoding="UTF-8"?><record_update table="sys_ui_macro">
    <sys_ui_macro action="INSERT_OR_UPDATE">
        <active>true</active>
        <category>general</category>
        <description>HTML Template used in the Angular Provider Directive: dtechDuration&#13;
</description>
        <media_type/>
        <name>dtechDuration.html</name>
        <scoped_name>x_153465_discovert_dtechDuration.html</scoped_name>
        <sys_class_name>sys_ui_macro</sys_class_name>
        <sys_created_by>rjoy</sys_created_by>
        <sys_created_on>2023-04-07 13:17:00</sys_created_on>
        <sys_id>345fb8791b0aa110e75655f5624bcb20</sys_id>
        <sys_mod_count>27</sys_mod_count>
        <sys_name>dtechDuration.html</sys_name>
        <sys_package display_value="Tasker" source="x_153465_discovert">c6b1162d4fc10300303dc3818110c7b1</sys_package>
        <sys_policy/>
        <sys_scope display_value="Tasker">c6b1162d4fc10300303dc3818110c7b1</sys_scope>
        <sys_update_name>sys_ui_macro_345fb8791b0aa110e75655f5624bcb20</sys_update_name>
        <sys_updated_by>rjoy</sys_updated_by>
        <sys_updated_on>2023-04-11 00:25:45</sys_updated_on>
        <xml><![CDATA[<div role="button"
	 ng-click="d.openModal($event);d.leaveTooltip();"> 

	<div ng-mouseenter="d.showDuration($event);" 
		 ng-mouseleave="d.parentMouseLeave();"> 

		<div uib-popover-template="'template-duration.html'"
			 popover-trigger="none"
			 popover-is-open="dtechDurationToolTipOpen"
			 popover-placement="auto"
			 popover-animation="true"
			 popover-class="dtech-popover-container-duration" 
			 popover-append-to-body="dtechIsModal==false"
			 popover-popup-delay="250">
			<div class="flex-row">
				<img ng-if="dtechStatus=='Critical'" 
					 ng-class="{'dtech-pad-right-10':dtechStatus=='Critical'}"
					 src="x_153465_discovert.Error16.svg"/>
				<img ng-if="dtechStatus=='Warning'" 
					 ng-class="{'dtech-pad-right-10':dtechStatus=='Warning'}"
					 src="x_153465_discovert.Warning16.svg"/>
				<img ng-if="!(dtechStatus == 'Warning' || dtechStatus == 'Critical')" 
					 ng-class="{'dtech-pad-right-10': !(dtechStatus == 'Warning' || dtechStatus == 'Critical')}"
					 src="Schedule16.svg"/>
				<span class="text-nowrap" ng-if="dtechShowLongDates!=true">
					<a class="dtech-avatar-link">{{dtechSuspenseDate}}</a>
				</span>
				<span class="text-nowrap" ng-if="dtechShowLongDates==true">
					<a class="dtech-avatar-link">{{dtechSuspenseDate.substring(0,10)| date : 'MMMM d, y'}}</a>
				</span>
			</div>
		</div>
	</div>
	<script type="text/ng-template" id="template-duration.html">
		<div ng-mouseenter="d.enterTooltip();"
			 ng-mouseleave="d.leaveTooltip();"
			 class="flex-column">
<!-- TODO discuss with Mark McCune if we should make this universal or create a different class for Duration -->
			<div class="dtech-template-response-container">
				<div ng-if="dtechStatusReason.length>0" class="panel panel-default">
					<div class="panel-heading">
						<div class="flex-row">
							<img ng-if="dtechStatus=='Critical'" 
								 ng-class="{'dtech-pad-right-10':dtechStatus=='Critical'}"
								 src="x_153465_discovert.Error16.svg"/>
							<img ng-if="dtechStatus=='Warning'" 
								 ng-class="{'dtech-pad-right-10':dtechStatus=='Warning'}"
								 src="x_153465_discovert.Warning16.svg"/>
							<img ng-if="!(dtechStatus == 'Warning' || dtechStatus == 'Critical')" 
								 ng-class="{'dtech-pad-right-10': !(dtechStatus == 'Warning' || dtechStatus == 'Critical')}"
								 src="Schedule16.svg"/>
							<h3 class="panel-title">{{dtechStatusReason}}</h3>
						</div>
					</div>
				</div>
				<div ng-if="d.isSpinnerShown">
					<div class="dtech-popover-list-spinner-content">
						<fa name="spinner" spin="true"></fa>
					</div>
				</div>
				<div class="flex-row"
					 ng-if="!d.isSpinnerShown">
					<div class="flex-column dtech-pad-all-10">
						<div ng-if="dtechDurationObject.outbound.value==true"
							 class="flex-row">
							<p>{{dtechDurationObject.outbound.label}}</p>
						</div>
						<div ng-if="dtechDurationObject.outbound.value==true"
							 class="flex-row">
							<p>{{dtechDurationObject.outbound.display_value}}</p>
						</div>
						<div class="flex-row">
							<p>{{dtechDurationObject.warning_hours.label}}</p>
						</div>
						<div class="flex-row">
							<p>{{dtechDurationObject.warning_hours.display_value}}</p>
						</div>
						<div class="flex-row">
							<p>{{dtechDurationObject.expected_start.label}}</p>
						</div>
						<div class="flex-row">
							<p>{{dtechDurationObject.expected_start.display_value}}</p>
						</div>
						<div class="flex-row">
							<p>{{dtechDurationObject.calendar_duration.label}}</p>
						</div>
						<div class="flex-row">
							<p>{{dtechDurationObject.calendar_duration.display_value}}</p>
						</div>
						<div class="flex-row">
							<p></p>
						</div>
						<div class="flex-row">
							<p></p>
						</div>
					</div>
					<div class="flex-column dtech-pad-all-10">
						<div ng-if="dtechDurationObject.outbound.value==true"
							 class="flex-row">
							<p>{{dtechDurationObject.u_external_due_date.label}}</p>
						</div>
						<div ng-if="dtechDurationObject.outbound.value==true"
							 class="flex-row">
							<p>{{dtechDurationObject.u_external_due_date.display_value}}</p>
						</div>
						
						<div class="flex-row">
							<p>{{dtechDurationObject.task_order.label}}</p>
						</div>
						<div class="flex-row">
							<p>{{dtechDurationObject.task_order.display_value}}</p>
						</div>
						<div class="flex-row">
							<p>{{dtechDurationObject.u_wait_for_subtasks_to_finish.label}}</p>
						</div>
						<div class="flex-row">
							<p>{{dtechDurationObject.u_wait_for_subtasks_to_finish.display_value}}</p>
						</div>
						<div class="flex-row">
							<p>{{dtechDurationObject.work_start.label}}</p>
						</div>
						<div class="flex-row">
							<p>{{dtechDurationObject.work_start.display_value}}</p>
						</div>
						<div class="flex-row">
							<p>{{dtechDurationObject.work_end.label}}</p>
						</div>
						<div class="flex-row">
							<p>{{dtechDurationObject.work_end.display_value}}</p>
						</div>
					</div>
				</div>
			</div>
			<div class="dtech-flex-shrink-0">
				<div class="dtech-pad-top-10">
					<div class="dtech-avatar-link dtech-display-block text-center" ng-click="d.openModal($event)">
						${gs.getMessage("Tasker - Open Duration")}
					</div>
				</div>
			</div>
		</div>
	</script>
</div>
]]></xml>
    </sys_ui_macro>
</record_update>
