        <script><![CDATA[// Copyrights belong to Discover Technologies LLC. © 2019 Discover Technologies LLC
// Script Continued Below
// KT - REQUEST TYPE
submitRequest(current);

function submitRequest(current){
	new Task_uiAction().uiAction_SubmitRequest(current);
	// STRY0104349 - Redirect platform to stay on task
	if (typeof spModal == 'undefined' ) {
		var task = new GlideRecord('x_153465_discovert_route_task_instance');
		if(task.get(current.getValue('parent'))){
			task.update();
			action.setRedirectURL(task);
		} else{
			action.setRedirectURL(current);   
		}
	}		
}]]></script>
