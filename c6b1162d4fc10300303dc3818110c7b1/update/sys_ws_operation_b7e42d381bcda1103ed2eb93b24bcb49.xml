        <http_method>GET</http_method>
        <name>Get User Profile</name>
        <operation_script><![CDATA[(function process(/*RESTAPIRequest*/ request, /*RESTAPIResponse*/ response) {

	var userId = request.pathParams.userId;
	var userProfile = _userProfile(userId);
	response.setBody({
		user: userId,
		userProfile: userProfile
	});
	
	response.setStatus(200);
	response.setContentType('application/json');
	
	function _userProfile(userId){
		var userInfo = new UserInfoScripts();
		var lProfile = userInfo.loadProfileInfo(userId);
		var photo = userInfo.loadPhotoInfo(userId, false);
		lProfile.photo = photo.photo;
		return lProfile;
	}
	
})(request, response);]]></operation_script>
