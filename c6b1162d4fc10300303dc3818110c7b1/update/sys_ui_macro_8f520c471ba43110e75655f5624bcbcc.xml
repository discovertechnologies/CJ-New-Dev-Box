        <sys_updated_on>2023-11-30 15:05:39</sys_updated_on>
        <xml><![CDATA[<span role="button"
	 ng-click="d.openModal($event);d.leaveTooltip();"> 

	<span ng-mouseenter="d.showOperational($event);" 
		 ng-mouseleave="d.parentMouseLeave();">

		<span uib-popover-template="d.popoverTemplate"
			 popover-trigger="none"
			 popover-is-open="dtechOperationalToolTipOpen"
			 popover-placement="auto"
			 popover-animation="true"
			 popover-class="dtech-popover-container-duration" 
			 popover-append-to-body="dtechIsModal==false"
			 popover-popup-delay="{{d.popoverDelay}}">
			<span ng-if="dtechShowLabel==true"
				  class="flex-row text-nowrap text-uppercase">
				{{dtechOperationalObject[dtechField].label}}
			</span>
			<span ng-class="{'flex-row':dtechField}">
				<img ng-class="{'dtech-pad-right-10':dtechField, 'dtech-pad-all-10':!dtechField }"
					 src="Information16_Black.svg"/>
				<span  ng-if="dtechField"
					  class="text-nowrap">
					<a class="dtech-avatar-link">{{dtechOperationalObject[dtechField].display_value}}</a>
				</span>
			</span>
		</span>
	</span>
	<script type="text/ng-template" id="task-popover-operational.html">
		<div ng-mouseenter="d.enterTooltip();"
			 ng-mouseleave="d.leaveTooltip();"
			 ng-init="d.initTooltip();"
			 class="flex-column">
			<div >
				<div class="panel panel-default">
					<div class="panel-heading">
						<div class="modal-header {{dtechOperationalObject.state.display_value}}">
							<h3 class="panel-title">{{dtechOperationalObject.operationalTitle}}</h3>
						</div>
					</div>
				</div>
				<div ng-if="d.isSpinnerShown">
					<div class="dtech-popover-list-spinner-content">
						<fa name="spinner" spin="true"></fa>
					</div>
				</div>
				<div class="dtech-template-container-270 modal-body task-info-tooltip-body"
					 ng-if="!d.isSpinnerShown">
					<div class="row">
						<div class="flex-row">
							<div ng-if="dtechOperationalObject.classification.display_value.length>0" class="ng-scope"> 
								<div class="taskform-classification-banner taskform-classification-banner-default taskform-classification-banner-office"> 
									<div title="Classification: Official" class="ng-binding">
										Official 
									</div> 
								</div> 
							</div>									
									
							<div class="badge taskform-classification-banner-default taskform-classification-banner-{{dtechOperationalObject.classification.value}}" 
								ng-show="dtechOperationalObject.classification.display_value.length > 0"> 
								<span title="Classification: {{dtechOperationalObject.classification.diplay_value}}">{{dtechOperationalObject.classification.display_value}}</span>
							</div>
							<div class="badge restricted-group" ng-show="dtechOperationalObject.assignment_group.display_value.length > 0"> 
								<span title="Restricted Group: {{dtechOperationalObject.assignment_group.display_value}}">{{dtechOperationalObject.assignment_group.display_value}}</span>
							</div>
							<div class="taskertype dtech-push-right-flexbox" ng-show="dtechOperationalObject.tasker_type.display_value.length > 0">
								<span title="Task Type: {{dtechOperationalObject.tasker_type.display_value}}">{{dtechOperationalObject.tasker_type.display_value}}</span>
							</div>
						</div>
					</div>
					<div class="row">
						<div class="col-sm-12 ">
							<label for="objective">
								<h4>{{dtechOperationalObject.u_top_task.u_objective.label}}:</h4>
							</label>
							<p id="objective" class="task-info-tooltip-objective" ng-bind-html="dtechOperationalObject.u_top_task.u_objective.display_value"></p>
						</div>
					</div>
					<div class="row">
						<div class="col-sm-12 ">
							<label for="instructions">
								<h4>{{dtechOperationalObject.instructions.label}}:</h4>
							</label>
							<p id="instructions" class="task-info-tooltip-objective" ng-bind-html="dtechOperationalObject.instructions.display_value"></p>
						</div>
					</div>

				</div>
				<div class="dtech-flex-shrink-0">
					<div class="dtech-pad-top-10">
						<div class="dtech-avatar-link dtech-display-block text-center" ng-click="d.openModal($event)">
							${gs.getMessage("Tasker - Open Information")}
						</div>
					</div>
				</div>
			</div>
		</div>
	</script>
	<script type="text/ng-template" id="templateTask-popover-operational.html">
		<div ng-mouseenter="d.enterTooltip();"
			 ng-mouseleave="d.leaveTooltip();"
			 ng-init="d.initTooltip();"
			 class="flex-column">
			<div >
				<div class="panel panel-default">
					<div class="panel-heading">
						<div >
							<h3 class="panel-title">{{dtechOperationalObject.operationalTitle}}</h3>
						</div>
					</div>
				</div>
				<div ng-if="d.isSpinnerShown">
					<div class="dtech-popover-list-spinner-content">
						<fa name="spinner" spin="true"></fa>
					</div>
				</div>
				<div class="dtech-template-container-270 modal-body task-info-tooltip-body"
					 ng-if="!d.isSpinnerShown">
					<div class="row">
						<div class="col-sm-12 ">
							<label for="objective">
								<h4>{{dtechOperationalObject.tasker_process_definition.u_objective.label}}:</h4>
							</label>
							<p id="objective" class="task-info-tooltip-objective" ng-bind-html="dtechOperationalObject.tasker_process_definition.u_objective.display_value"></p>
						</div>
					</div>
					<div class="row">
						<div class="col-sm-12 ">
							<label for="instructions">
								<h4>{{dtechOperationalObject.instructions.label}}:</h4>
							</label>
							<p id="instructions" class="task-info-tooltip-objective" ng-bind-html="dtechOperationalObject.instructions.display_value"></p>
						</div>
					</div>

				</div>
				<div class="dtech-flex-shrink-0">
					<div class="dtech-pad-top-10">
						<div class="dtech-avatar-link dtech-display-block text-center" ng-click="d.openModal($event)">
							${gs.getMessage("Tasker - Open Information")}
						</div>
					</div>
				</div>
			</div>
		</div>
	</script>	
</span>
]]></xml>
    </sys_ui_macro>
</record_update>
