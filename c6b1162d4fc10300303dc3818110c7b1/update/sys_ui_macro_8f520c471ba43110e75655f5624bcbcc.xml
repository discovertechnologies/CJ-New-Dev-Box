			 popover-trigger="none"
			 popover-is-open="dtechToolTipOpen"
			 popover-placement="{{dtechPopoverPlacement}}"
			 popover-animation="true"
			 popover-class="dtech-popover-container-box-shadow dtech-width-400px" 
			 popover-append-to-body="dtechIsModal==false"
			 popover-popup-delay="{{d.popoverDelay}}">
			<span ng-if="dtechShowLabel==true"
				  class="flex-row text-nowrap text-uppercase">
				{{dtechOperationalObject[dtechField].label}}
			</span>
			<span class="text-nowrap"
				ng-class="d.getBtnClass()">
				<img ng-class="{'dtech-pad-right-10':dtechField}"
					 src="{{d.getImage()}}"/>
				<span  ng-if="dtechField"
					class="text-nowrap dtech-text-overflow-ellipsis"
					ng-style="{'max-width':dtechMaxWidthPx}">
					{{dtechOperationalObject[dtechField].display_value}}
				</span>
			</span>
		</span>
	</span>
	<script type="text/ng-template" id="task-popover-operational.html">
		<div ng-mouseenter="d.enterTooltip();"
			 ng-mouseleave="d.leaveTooltip();"
			 ng-init="d.initTooltip();"
			 class="flex-column">
			<div>			 
				<div class="panel panel-default">				
					<div class="panel-heading">
						<div class="flex-row">
							<img class="dtech-pad-right-10"
								src="Information16_Black.svg"/>
							<div class="flex-grow">
								<h3 class="panel-title">${gs.getMessage("Task Information")}</h3>
							</div>
							<div class="taskertype dtech-push-right-flexbox" ng-show="dtechOperationalObject.tasker_type.display_value.length > 0">
								<span title="Task Type: {{dtechOperationalObject.tasker_type.display_value}}">{{dtechOperationalObject.tasker_type.display_value}}</span>
							</div>
						</div>
					</div>
				</div>
				<div ng-if="dtechOperationalObject.loaded!=true">
					<div class="dtech-popover-list-spinner-content">
						<fa name="spinner" spin="true"></fa>
					</div>
				</div>
				<div class="dtech-template-container-270 flex-column"
						ng-if="dtechOperationalObject.loaded==true">
					<div class="dtech-w-100p">
						<div >
							<div ng-if="dtechOperationalObject.classification.display_value.length>0" class="ng-scope"> 
								<div class="taskform-classification-banner taskform-classification-banner-default taskform-classification-banner-{{dtechOperationalObject.classification.value}}"> 
									<div title="Classification: {{dtechOperationalObject.classification.display_value}}" class="ng-binding">
										{{dtechOperationalObject.classification.display_value}}
									</div> 
								</div> 
							</div>
						</div>
					</div>				

					<div class="row dtech-w-100p dtech-pad-top-10">
						<div class="col-sm-12 dtech-modal-widget-text-black-bold">
							<p>{{dtechOperationalObject.short_description.label}}</p>
						</div>
					</div>
					<div class="row dtech-w-100p">
						<div class="col-sm-12 dtech-sonic-silver-text-color">
							<p>{{dtechOperationalObject.short_description.display_value}}</p>
						</div>
					</div>
					<div class="row dtech-w-100p">
						<div class="col-sm-12 dtech-modal-widget-text-black-bold">
							<p>{{dtechOperationalObject.u_top_task.u_objective.label}}</p>
						</div>
					</div>
					<div class="row dtech-w-100p">
						<div class="col-sm-12">
							<p ng-bind-html="dtechOperationalObject.u_top_task.u_objective.display_value"></p>
						</div>
					</div>
					<div class="row dtech-w-100p">
						<div class="col-sm-12 dtech-modal-widget-text-black-bold">
							<p>{{dtechOperationalObject.instructions.label}}</p>
						</div>
					</div>
					<div class="row dtech-w-100p">
						<div class="col-sm-12">
							<p ng-bind-html="dtechOperationalObject.instructions.display_value"></p>
						</div>
					</div>
					<div ng-if="hasSignatureInstructions"
						class="row dtech-w-100p">
						<div class="col-sm-12 dtech-modal-widget-text-black-bold">
							<p>{{dtechOperationalObject.u_signature_instructions.label}}</p>
						</div>
					</div>
					<div ng-if="hasSignatureInstructions"
