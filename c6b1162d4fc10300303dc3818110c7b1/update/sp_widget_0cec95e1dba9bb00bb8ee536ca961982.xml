<?xml version="1.0" encoding="UTF-8"?><record_update table="sp_widget">
    <sp_widget action="INSERT_OR_UPDATE">
        <category>custom</category>
        <client_script><![CDATA[function ($scope,$http, spUtil,$rootScope) {
	var c = this;
	if (!c.options.table)
		return;
	
	spUtil.recordWatch($scope, c.options.table, c.options.filter);
	c.params = {
		'filter' : c.options.filter,
		'sp_page_dv' : c.options.sp_page_dv,
		'table' : c.options.table,
		'title' : c.options.title,
		'glyph' : c.options.glyph
	};
	
	c.getData = function(){
		$rootScope.$broadcast('countPanelClicked', c.params);
	}

}]]></client_script>
        <controller_as>c</controller_as>
