        <name>tasker-out-of-office-native-ui.css</name>
        <style>/*&#13;
Collection of CSS that is used in Out of Office&#13;
&#13;
ANY CHANGES MADE IN THIS FILE ALSO NEED TO BE MADE IN the stylesheet  file "tasker_out_of_office"  in the tasker theme. &#13;
&#13;
2.8.1 | 2022-09-21| raj  |  STRY0130635 - Task Form- Assignee is Out of Office&#13;
&#13;
*/&#13;
&#13;
.dtech-ooo-list-message-item{&#13;
    padding:2px;&#13;
}&#13;
&#13;
.dtech-ooo-message-text{&#13;
  color:#92386F;&#13;
  font-size:14px;&#13;
}&#13;
&#13;
.dtech-ooo-message-container{&#13;
  padding:10px;&#13;
  background-color: #f4f4f4;&#13;
  border-radius: 0px 0px 5px 5px;&#13;
  cursor: pointer;&#13;
}&#13;
&#13;
.dtech-ooo-background-color{&#13;
  background-color: #f4f4f4;&#13;
}&#13;
&#13;
.dtech-ooo-pad-right-10{&#13;
  padding-right:10px;&#13;
}&#13;
&#13;
.dtech-ooo-tooltip-html {&#13;
  max-width: 400px !important;&#13;
  background-color:#FFFFFF;&#13;
  color:#000000;&#13;
  font-size:14px;&#13;
}&#13;
&#13;
/* This is also in "Tasker Overall Style Sheet" for portal&#13;
 color that is #FFFFFF was - $tasker-popover-arrow-color&#13;
*/&#13;
.dtech-ooo-arrow-up:before {&#13;
  border-bottom: 10px solid #FFFFFF;&#13;
  border-left: 10px solid transparent;&#13;
  border-right: 10px solid transparent;&#13;
  content: '';&#13;
  height: 0;&#13;
  left: calc(100% / 2 - 10px); &#13;
  position: absolute;&#13;
  top: -10px;&#13;
  width: 0;&#13;
  z-index: 2;&#13;
}&#13;
&#13;
.dtech-ooo-arrow-up:after {&#13;
  border-bottom: 12px solid rgba(0, 0, 0, 0.1);&#13;
  border-left: 12px solid transparent;&#13;
  border-right: 12px solid transparent;&#13;
  content: '';&#13;
  height: 0;&#13;
  left: calc(100% / 2 - 12px);&#13;
  position: absolute;&#13;
  top: -12px; &#13;
  width: 0;&#13;
  z-index: 1;&#13;
}&#13;
&#13;
/* color that is #FFFFFF was - $tasker-popover-container-avatar-color */&#13;
.dtech-ooo-tooltip-container{&#13;
  background-color: #FFFFFF ;&#13;
  border-radius: 5px;&#13;
  padding: 10px 10px 10px 10px;&#13;
  left: -200px;&#13;
  position: absolute;&#13;
  width: 400px;&#13;
  box-shadow: 0px 0px 20px 0px rgba(0, 0, 0, 0.25);&#13;
  -webkit-box-shadow: 0px 0px 20px 0px rgba(0, 0, 0, 0.25);&#13;
  -moz-box-shadow: 0px 0px 20px 0px rgba(0, 0, 0, 0.25);&#13;
}</style>
