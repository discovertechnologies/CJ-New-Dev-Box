        <sys_name>dtechTaskerFiles.html</sys_name>
        <sys_package display_value="Tasker" source="x_153465_discovert">c6b1162d4fc10300303dc3818110c7b1</sys_package>
        <sys_policy/>
        <sys_scope display_value="Tasker">c6b1162d4fc10300303dc3818110c7b1</sys_scope>
        <sys_update_name>sys_ui_macro_aa6154f01bfc75103ed2eb93b24bcb9b</sys_update_name>
        <sys_updated_by>rjoy</sys_updated_by>
        <sys_updated_on>2023-09-08 02:52:15</sys_updated_on>
        <xml><![CDATA[<span role="button"
	 ng-click="d.openModal($event);d.leaveTooltip();"> 
	<span ng-mouseenter="d.showTaskerFiles($event);" 
		 ng-mouseleave="d.parentMouseLeave();">
		<span uib-popover-template="'template-tasker-files.html'"
			 popover-trigger="none"
			 popover-is-open="dtechTaskerFilesToolTipOpen"
			 popover-placement="auto"
			 popover-animation="true"
			 popover-class="dtech-popover-container-duration" 
			 popover-append-to-body="dtechIsModal==false"
			 popover-popup-delay="{{d.popoverDelay}}">
			<span ng-if="dtechShowLabel==true"
				  class="flex-row text-nowrap text-uppercase">
				{{dtechTaskerFilesObject.label}}
			</span>
			<span class="'flex-row'">
				<span class="btn btn-icon icon-paperclip" ></span>
				<span class="badge Draft" >
<!-- TODO - change out for file count property when set on server-->
					{{dtechTaskerFilesObject.calchaschildren.display_value}}
				</span>
			</span>
		</span>
	</span>
	<script type="text/ng-template" id="template-tasker-files.html">
		<div ng-mouseenter="d.enterTooltip();"
			 ng-mouseleave="d.leaveTooltip();"
			 ng-init="d.initTooltip();"
			 class="flex-column">
			<div class="dtech-template-container-270">
				<div ng-if="d.isSpinnerShown">
					<div class="dtech-popover-list-spinner-content">
						<fa name="spinner" spin="true"></fa>
					</div>
				</div>
				<div class="flex-column"
					 ng-if="!d.isSpinnerShown">
					<ul class="list-unstyled">
						<li class="dtech-margin-bottom-inherit" ng-repeat="file in dtechTaskerFilesObject.files | limitTo: maxRowsToDisplay track by file.taskId">
							<div class="flex-column">
								<span class="dtech-modal-widget-text-black-bold"
									  ng-click="itemClick(file.taskId)">{{file.short_description.display_value}}</span>
								<span class="dtech-state-indicator-row">
									<span class="dtech-circle dtech-circle-12 {{file.state.display_value}}"></span>
									<span class="flex-grow dtech-sonic-silver-text-color">{{file.state.display_value}}</span>
								</span>
							</div>
						</li>
					</ul>
				</div>
			</div>
			<div class="dtech-flex-shrink-0">
				<div class="dtech-pad-top-10">
					<div class="dtech-avatar-link dtech-display-block text-center" ng-click="d.openModal($event)">
						${gs.getMessage("Tasker - Open TaskerFiles")}
					</div>
				</div>
			</div>
		</div>
	</script>
</span>
]]></xml>
    </sys_ui_macro>
</record_update>
