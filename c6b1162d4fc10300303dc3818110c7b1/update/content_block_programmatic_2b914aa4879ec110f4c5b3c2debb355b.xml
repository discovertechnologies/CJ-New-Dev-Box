<?xml version="1.0" encoding="UTF-8"?><record_update table="content_block_programmatic">
    <content_block_programmatic action="INSERT_OR_UPDATE">
        <active>true</active>
        <category>general</category>
        <condition/>
        <conditional>false</conditional>
        <frame/>
        <logged_on>false</logged_on>
        <name>Tasks by OU Type</name>
        <programmatic_content><![CDATA[<?xml version="1.0" encoding="utf-8" ?>
<j:jelly trim="false" xmlns:j="jelly:core" xmlns:g="glide" xmlns:j2="null" xmlns:g2="null">

	<g:evaluate var="jvar_sOfficesWhereIamAMember" jelly="true" >
	var sOfficesWhereIamAMember = new x_153465_discovert.tasking_System_Settings_Scripts().getOUsWhereIamAMember().join(',');
	sOfficesWhereIamAMember;
	</g:evaluate>

	<g:evaluate var="jvar_sOfficesWhereIamATaskManagers" jelly="true" >
	var sOfficesWhereIamATaskManagers= new x_153465_discovert.tasking_System_Settings_Scripts().getMyOUTaskManagers().join(',');
	sOfficesWhereIamATaskManagers;
	</g:evaluate>	
	
	<script>
     var my_dashboardMessageHandler = new DashboardMessageHandler("content_block_programmatic_2b914aa4879ec110f4c5b3c2debb355b");

	function updateFilter() {
	 var sOfficesWhereIamAMember = "${jvar_sOfficesWhereIamAMember}";
	 var sOfficesWhereIamATaskManagers = "${jvar_sOfficesWhereIamATaskManagers}";
	 var filter_message = {};
	 var sFilter = "";
	 var taskingAuthorityChecked = document.getElementById('dt_filter_tasking_authority').checked;
	 var primaryOfficeChecked = document.getElementById('dt_filter_primary_office').checked;
	 var primaryAssigneeChecked = document.getElementById('dt_filter_primary_assignee').checked;
		
	 filter_message.id = "content_block_programmatic_2b914aa4879ec110f4c5b3c2debb355b";
	 filter_message.filter = "";
	 
	 if(taskingAuthorityChecked){ 
		sFilter = 'tasking_authorityIN' + sOfficesWhereIamAMember;
		alert(sFilter);
	 }
	 if(primaryOfficeChecked){ 
		sFilter = sFilter=='' ? '' : sFilter + '^OR';
		sFilter += 'primary_officeIN' + sOfficesWhereIamAMember;
		alert(sFilter);
	 }
	 if(primaryAssigneeChecked){ 
		sFilter = sFilter=='' ? '' : sFilter + '^OR';
		sFilter += 'primary_assigneeIN' + sOfficesWhereIamAMember;
		alert(sFilter);
	 }
	
	 filter_message.table = "x_153465_discovert_route_task_instance";
	 filter_message.filter = sFilter;
	 SNC.canvas.interactiveFilters.setDefaultValue({
		id: filter_message.id,
		filters: [filter_message]
		}, false);
	 my_dashboardMessageHandler.publishFilter(filter_message.table, filter_message.filter);
    }

    function setFilter() {
	    var filter_message = {};
        filter_message.id = "content_block_programmatic_2b914aa4879ec110f4c5b3c2debb355c";
        filter_message.table = "task";
        filter_message.filter = "";
       SNC.canvas.interactiveFilters.setDefaultValue({
			id: filter_message.id,
			filters: [filter_message]
			}, false);
        my_dashboardMessageHandler.removeFilter();
        filter_message.table = "x_153465_discovert_route_task_instance";
        filter_message.filter = sFilter;
	    SNC.canvas.interactiveFilters.setDefaultValue({
		    id: filter_message.id,
		    filters: [filter_message]
		    }, false);
	 my_dashboardMessageHandler.publishFilter(filter_message.table, filter_message.filter);
    } 		
		
 </script>   
	Filter my tasks by OU type:
    ${jvar_sOfficesWhereIamAMember}
    <br>${jvar_sOfficesWhereIamATaskManagers}</br> 
	

<div class="widget-content interactive-filter__widget-content" role="group" aria-labelledby="header-title-test">

<div class="row interactive-filter__row">
<span class="input-group-checkbox">
<input class="checkbox" id="dt_filter_tasking_authority" type="checkbox" value="0" name="tasking_authority" aria-checked="false" onchange="updateFilter();">
<label for="dt_filter_tasking_authority" class="checkbox-label">Tasking Authority
</label></input></span></div>
	
<div class="row interactive-filter__row">
<span class="input-group-checkbox">
<input class="checkbox" id="dt_filter_primary_office" type="checkbox" value="1" name="primary_office" aria-checked="false" onchange="updateFilter();">
<label for="dt_filter_primary_office" class="checkbox-label">Primary Office
</label></input></span></div>
	
<div class="row interactive-filter__row">
<span class="input-group-checkbox">
<input class="checkbox" id="dt_filter_primary_assignee" type="checkbox" value="2" name="primary_assignee" aria-checked="false" onchange="updateFilter();">
<label for="dt_filter_primary_assignee" class="checkbox-label">Primary Assignee
</label></input></span></div></div>

</j:jelly>]]></programmatic_content>
