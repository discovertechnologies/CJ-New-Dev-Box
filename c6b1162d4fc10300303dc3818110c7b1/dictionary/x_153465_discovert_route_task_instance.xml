&#9;dateStatus = &quot;No Suspense Date&quot;;&#10;&#9;&#9;}&#10;&#9;&#9;// Pull Risk Information&#10;&#9;&#9;if(current.risk_flag == 2){&#10;&#9;&#9;&#9;riskStatus = &quot;High Risk&quot;;&#10;&#9;&#9;}&#10;&#9;&#9;else if (current.risk_flag == 1) {&#10;&#9;&#9;&#9;riskStatus = &quot;Medium Risk&quot;;&#10;&#9;&#9;}&#10;&#9;&#9;else if (current.risk_flag == 0) {&#10;&#9;&#9;&#9;riskStatus = &quot;Low Risk&quot;;&#10;&#9;&#9;}&#10;&#9;&#9;&#10;&#9;&#9;if ((dateStatus == &quot;Overdue&quot;)  || (riskStatus == &quot;High Risk&quot;)){&#10;&#9;&#9;&#9;//gs.info('Status changed to Critical: ' + current.task_name);&#10;&#9;&#9;&#9;current.status = &quot;Critical&quot;;&#10;&#9;&#9;}&#10;&#9;&#9;else if ((dateStatus == &quot;Warning&quot;)  || (riskStatus == &quot;Medium Risk&quot;)){&#10;&#9;&#9;&#9;current.status = &quot;Warning&quot;;&#10;&#9;&#9;}&#10;&#9;&#9;else{&#10;&#9;&#9;&#9;current.status = &quot;Projected on time&quot;;&#10;&#9;&#9;}&#10;&#9;}&#10;&#9;//gs.info('Status Calculated field: final status after calculationg: ' + now + ' - ' + current.task_number + ' current.status: ' + current.status);&#10;&#9;return current.status;&#10;})(current);" label="Status" max_length="50" name="status" read_only="true" type="string"/>
